{
  "name": "planner",
  "version": "1.0.0",
  "description": "PlanneR Application",
  "scripts": {
    "start": "cds serve",
    "deploy": "cds deploy && npm run restore:db",
    "backup:db": "node scripts/backup-sqlite.js",
    "restore:db": "node scripts/restore-from-backup.js"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.2.0",
    "@sap/cds-dk": "^9.9.0"
  },
  "cds": {
    "requires": {
      "auth": "dummy",
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      }
    }
  },
  "dependencies": {
    "@sap/cds-dk": "^9.9.0",
    "@cap-js/sqlite": "^2.2.0",
    "@sap/xssec": "^4.13.0"
  }
}
