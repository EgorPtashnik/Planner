<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:core='sap.ui.core'>

    <Table
        id='idTodoList'
        sticky='HeaderToolbar'
        fixedLayout='false'
        autoPopinMode='true'
        items='{
            path: "todo>/List",
            parameters: {
                $count: true,
                $expand: "items,doneItems,tag"
            }
        }'>

        <noData>
            <IllustratedMessage
                title='Нет данных'
                description='Создайте новый список чтобы увидеть данные.'
                illustrationType='sapIllus-NoActivities' />
        </noData>

        <headerToolbar>
            <OverflowToolbar>
                <ToolbarSpacer />
                
                <Button
                    press='onPressCreateList'
                    type='Ghost'
                    text='Создать'
                    tooltip='Создать'>
                    <layoutData>
                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                    </layoutData>
                </Button>

                <OverflowToolbarButton
                    press='onPressManageListTags'
                    icon='sap-icon://tags'
                    tooltip='Управление тегами'
                    text='Теги'>
                    <layoutData>
                        <OverflowToolbarLayoutData group='1' />
                    </layoutData>
                </OverflowToolbarButton>

                <OverflowToolbarButton
                    press='onPressTodoListSort'
                    type='Transparent'
                    icon='sap-icon://sort'
                    text='Сортировка'
                    tooltip='Сортировка'>
                    <layoutData>
                        <OverflowToolbarLayoutData group='1' />
                    </layoutData>
                </OverflowToolbarButton>
            </OverflowToolbar>
        </headerToolbar>

        <columns>
            <Column
                autoPopinWidth='20'
                importance='High'>
                <Text text='Имя' />
            </Column>

            <Column
                width='8rem'
                popinDisplay='WithoutHeader'>
                <Text text='Статус' />
            </Column>
        </columns>

        <items>
            <ColumnListItem
                press='onPressListItem'
                navigated='{= %{/detailID} === %{todo>ID} }'
                highlight='{= %{/detailID} === %{todo>ID} ? "Information" : "None" }'
                type='{= %{/detailID} === %{todo>ID} ? "Active" : "Navigation" }'>
                <cells>
                    <HBox alignItems='Center'>
                        <GenericTag
                            class='sapUiTinyMarginEnd'
                            design='StatusIconHidden'
                            text='{ path: "todo>priority", formatter: ".Formatter.getPriorityText" }'
                            status='{ path: "todo>priority", formatter: ".Formatter.getPriorityState" }' />
                        <ObjectIdentifier
                            title='{todo>name}' />
                    </HBox>

                    <ObjectStatus
                        class='sapMObjectStatusLongText'
                        text='{ path: "todo>status", formatter: ".Formatter.getProgressStatusText" }'
                        state='{ path: "todo>status", formatter: ".Formatter.getProgressStatusState" }' />
                </cells>
            </ColumnListItem>
        </items>

    </Table>

</core:FragmentDefinition>