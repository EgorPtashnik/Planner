<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:core='sap.ui.core'>

    <Dialog
        showHeader='false'
        horizontalScrolling='false'
        stretch='{device>/system/phone}'>

        <content>
            <Table
                id='idTodoTagList'
                delete='onPressDeleteListTag'
                mode='Delete'
                busyIndicatorDelay='0'
                fixedLayout='false'
                alternateRowColors='true'
                autoPopinMode='true'
                sticky='HeaderToolbar'
                items='{
                    path: "todo>/ListTag",
                    parameters: { $orderby: "createdAt desc" }
                }'>
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text='Теги ({state>/tagCount})' />

                        <ToolbarSpacer />

                        <Button
                            press='onPressCreateListTag'
                            type='Ghost'
                            text='Создать'
                            tooltip='Создать новый тег' />
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column>
                        <Text text='Имя' />
                    </Column>
                    
                    <Column>
                        <Text text='Цвет' />
                    </Column>
                    
                    <Column>
                        <Text text='Описание' />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <Input value='{todo>name}' />

                            <Select
                                selectedKey='{todo>color}'>
                                <items>
                                    <core:ListItem key='None' text='Серый' />
                                    <core:ListItem key='Information' text='Синий' />
                                    <core:ListItem key='Warning' text='Оранжевый' />
                                    <core:ListItem key='Error' text='Красный' />
                                    <core:ListItem key='Success' text='Зеленый' />
                                </items>
                            </Select>

                            <Input value='{todo>info}' />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>

        <buttons>
            <Button
                press='onPressCloseDialog'
                text='Закрыть'
                tooltip='Закрыть' />
        </buttons>
    </Dialog>

</core:FragmentDefinition>