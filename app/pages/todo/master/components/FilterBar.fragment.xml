<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:fb='sap.ui.comp.filterbar'
    xmlns:core='sap.ui.core'>
    
    <f:DynamicPageHeader>
        <fb:FilterBar showGoOnFB="false" useToolbar="false">
            <fb:filterGroupItems>

                <fb:FilterGroupItem name="fbSearch" label="Поиск" groupName="basic" visibleInFilterBar="true">
                    <fb:control>
                        <SearchField change='onChangeTodoListSearch' />
                    </fb:control>
                </fb:FilterGroupItem>

                <fb:FilterGroupItem name="fbListTag" label="Тег" groupName="basic" visibleInFilterBar="true">
                    <fb:control>
                        <MultiComboBox
                            id='idTodoListTagFilter'
                            selectionFinish='onChangeTodoListFilter'
                            selectedKeys='{config>/filterBar/ListTag}'
                            items='{todo>/ListTag}'>
                            <items>
                                <core:Item key='{todo>ID}' text='{todo>name}' />
                            </items>
                        </MultiComboBox>
                    </fb:control>
                </fb:FilterGroupItem>

                <fb:FilterGroupItem name="fbPriority" label="Приоритет" groupName="basic" visibleInFilterBar="true">
                    <fb:control>
                        <MultiComboBox
                            selectionFinish='onChangeTodoListFilter'
                            selectedKeys='{config>/filterBar/Priority}'
                            items='{common>/PriorityCode}'>
                            <items>
                                <core:Item key='{common>code}' text='{common>name}' />
                            </items>
                        </MultiComboBox>
                    </fb:control>
                </fb:FilterGroupItem>

            </fb:filterGroupItems>
        </fb:FilterBar>
    </f:DynamicPageHeader>

</core:FragmentDefinition>