<mvc:View
    xmlns='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    busyIndicatorDelay='0'
	controllerName='planner.pages.todo.master.TodoMaster'>

    <DynamicPage headerExpanded='false'>

        <title>
            <core:Fragment fragmentName='planner.pages.todo.master.components.Header' type='XML' />
        </title>

        <header>
            <core:Fragment fragmentName='planner.pages.todo.master.components.FilterBar' type='XML' />
        </header>

        <content>
            <core:Fragment fragmentName='planner.pages.todo.master.components.TodoList' type='XML' />
        </content>

    </DynamicPage>

</mvc:View>