<mvc:View
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:core='sap.ui.core'
    xmlns:mvc='sap.ui.core.mvc'
    busyIndicatorDelay='0'
	controllerName='planner.pages.todo.detail.TodoDetail'>

    <uxap:ObjectPageLayout
        preserveHeaderStateOnScroll='true'
        upperCaseAnchorBar='false'>

        <!-- HEADER -->
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>

                <uxap:breadcrumbs>
                    <Breadcrumbs currentLocationText='{todo>name}'>
                        <links>
                            <Link press='onPressClosePage' text='Дела' />
                        </links>
                    </Breadcrumbs>
                </uxap:breadcrumbs>

                <uxap:navigationActions>
                    <Button
                        press='onPressToggleFullScreen(%{/layout} === "MidColumnFullScreen")'
                        icon='{= %{/layout} === "MidColumnFullScreen" ? "sap-icon://exit-full-screen" : "sap-icon://full-screen" }'
                        tooltip='Полный Экран'
                        visible='{= !%{/isOnlyOneColumn} }' />

                    <Button
                        press='onPressClosePage'
                        icon='sap-icon://decline' />
                </uxap:navigationActions>

                <uxap:actions>
                    <ToggleButton
                        press='onToggleEditMode'
                        type='Emphasized'
                        tooltip='Режим редактирования'
                        icon='sap-icon://edit'
                        pressed='{config>/editMode}'>
                        <layoutData>
                            <OverflowToolbarLayoutData priority='NeverOverflow' />
                        </layoutData>
                    </ToggleButton>

                    <Button
                        press='onPressDeleteTodoList'
                        text='Удалить'
                        tooltip='Удалить'
                        icon='sap-icon://delete'
                        type='Negative'>
                        <layoutData>
                            <OverflowToolbarLayoutData priority='AlwaysOverflow' />
                        </layoutData>
                    </Button>
                </uxap:actions>

                <uxap:snappedHeading>
                    <VBox>
                        <!-- DISPLAY -->
                        <Title
                            wrapping='true'
                            text='{todo>name}'
                            visible='{= !%{config>/editMode} }' />

                        <!-- EDIT -->
                        <Input
                            value='{todo>name}'
                            visible='{config>/editMode}' />
                    </VBox>
                </uxap:snappedHeading>

                <uxap:expandedHeading>
                    <VBox>
                        <!-- DISPLAY -->
                        <Title
                            wrapping='true'
                            text='{todo>name}'
                            visible='{= !%{config>/editMode} }' />
                        <GenericTag
                            design='StatusIconHidden'
                            status='{= %{todo>tag/color} || "None"}'
                            text='{= %{todo>tag/name} || "Нет" }'
                            visible='{= !%{config>/editMode} }' />

                        <!-- EDIT -->
                        <Input
                            value='{todo>name}'
                            visible='{config>/editMode}' />
                        <Select
                            forceSelection='false'
                            selectedKey='{todo>tag_ID}'
                            visible='{config>/editMode}'
                            items='{todo>/ListTag}'>
                            <items>
                                <core:Item key='{todo>ID}' text='{todo>name}' />
                            </items>
                        </Select>
                    </VBox>
                </uxap:expandedHeading>

                <uxap:expandedContent>
                    <ObjectStatus
                        title='Обновлено'
                        text='{todo>modifiedAt}'
                        visible='{= !%{config>/editMode} }' />
                </uxap:expandedContent>

            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>



        <!-- HEADER CONTENT -->
        <uxap:headerContent>

            <!-- DISPLAY MODE -->
            <VBox visible='{= !%{config>/editMode} }'>
                <Text
                    text='{= %{todo>info} || "Нет описания" }'
                    visible='{= !%{config>/editMode} }' />
            </VBox>

            <!-- EDIT MODE -->
            <VBox visible='{config>/editMode}' >
                <TextArea
                    width='100%'
                    rows='5'
                    value='{todo>info}' />
            </VBox>

        </uxap:headerContent>



        <!-- ITEMS -->
        <uxap:sections>
            <uxap:ObjectPageSection showTitle='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection showTitle='false'>

                        <uxap:blocks>
                            <Table
                                id='idTodoItems'
                                delete='onPressDeleteItem'
                                showSeparators='Inner'
                                autoPopinMode='true'
                                hiddenInPopin='{= %{config>/showDetails}.toString() === "true" || %{config>/editMode} ? [] : ["Low","Medium"] }'
                                mode='{= %{config>/editMode} ? "Delete" : "None"}'
                                items='{
                                    path: "todo>items",
                                    parameters: {
                                        $$ownRequest: true,
                                        $count: true,
                                        $orderby: "createdAt desc"
                                    }
                                }'>

                                <noData>
                                    <IllustratedMessage
                                        title='Шаги еще не добавлены'
                                        description='Создайте шаг чтобы увидеть данные.'
                                        illustrationType='sapIllus-NoActivities' />
                                </noData>

                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text='Шаги ({config>/itemCount})' />

                                        <ToolbarSpacer />

                                        <Button
                                            press='onPressCreateItem'
                                            type='Ghost'
                                            text='Создать'
                                            tooltip='Создать'
                                            visible='{config>/editMode}'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                                            </layoutData>
                                        </Button>

                                        <OverflowToolbarButton
                                            press='onPressToggleVisibleItems'
                                            type='Transparent'
                                            icon='{= %{config>/showCompletedItems} ? "sap-icon://hide" : "sap-icon://show" }'
                                            text='{= %{config>/showCompletedItems} ? "Скрыть" : "Показать" } Законченные'
                                            tooltip='{= %{config>/showCompletedItems} ? "Скрыть" : "Показать" } Законченные'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData group='1' />
                                            </layoutData>
                                        </OverflowToolbarButton>

                                        <OverflowToolbarButton
                                            press='onPressDeleteCompletedItems'
                                            type='Transparent'
                                            icon='sap-icon://eraser'
                                            text='Удалить Законченные'
                                            tooltip='Удалить Законченные'
                                            visible='{= !%{config>/editMode} }'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData group='1' />
                                            </layoutData>
                                        </OverflowToolbarButton>

                                        <OverflowToolbarButton
                                            press='onPressItemSort'
                                            type='Transparent'
                                            icon='sap-icon://sort'
                                            text='Сортировка'
                                            tooltip='Сортировка'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData group='1' />
                                            </layoutData>
                                        </OverflowToolbarButton>

                                        <OverflowToolbarToggleButton
                                            icon='sap-icon://detail-more'
                                            tooltip='Показать Детали'
                                            text='Показать Детали'
                                            visible='{= %{device>/system/phone} &amp;&amp; !%{config>/editMode} }'
                                            pressed='{config>/showDetails}'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData  group='1' />
                                            </layoutData>
                                        </OverflowToolbarToggleButton>

                                        <SegmentedButton
                                            selectedKey='{config>/showDetails}'
                                            visible='{= !%{device>/system/phone} &amp;&amp; !%{config>/editMode} }'>
                                            <items>
                                                <SegmentedButtonItem
                                                    key='false'
                                                    icon='sap-icon://detail-less'
                                                    tooltip='Скрыть Детали' />
                                                <SegmentedButtonItem
                                                    key='true'
                                                    icon='sap-icon://detail-more'
                                                    tooltip='Показать Детали' />
                                            </items>
                                            <layoutData>
                                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                                            </layoutData>
                                        </SegmentedButton>
                                    </OverflowToolbar>
                                </headerToolbar>

                                <columns>
                                    <Column
                                        width='auto'
                                        autoPopinWidth='10'
                                        importance='High' >
                                        <Text text='Имя'/>
                                    </Column>

                                    <Column
                                        width='8rem'
                                        importance='Medium'
                                        popinDisplay='Inline'>
                                        <Text text='Приоритет' />
                                    </Column>

                                    <Column
                                        importance='Low'
                                        autoPopinWidth='999'
                                        popinDisplay='{= %{config>/editMode} ? "Block" : "WithoutHeader" }'>
                                        <Text text='Заметка' />
                                    </Column>

                                    <Column
                                        width='8rem'
                                        hAlign='Right'
                                        importance='High'
                                        visible='{= !%{config>/editMode} }'>
                                        <Text text='Выполнение' />
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem
                                        visible='{=
                                            %{config>/showCompletedItems} ||
                                            %{todo>status} === 0 || %{todo>status} === 1
                                        }'>
                                        <cells>
                                            <VBox>
                                                <!-- DISPLAY -->
                                                <ObjectIdentifier
                                                    title='{todo>name}'
                                                    visible='{= !%{config>/editMode} }'/>
                                                <!-- EDIT -->
                                                <Input
                                                    width='100%'
                                                    value='{todo>name}'
                                                    visible='{config>/editMode}' />
                                            </VBox>

                                            <VBox>
                                                <!-- DISPLAY -->
                                                <ObjectStatus
                                                    text='{ path: "todo>priority", formatter: ".Formatter.getPriorityText" }'
                                                    state='{ path: "todo>priority", formatter: ".Formatter.getPriorityState" }'
                                                    visible='{= !%{config>/editMode} }' />
                                                <!-- EDIT -->
                                                <Select
                                                    width='100%'
                                                    selectedKey='{todo>priority}'
                                                    visible='{config>/editMode}'
                                                    items='{path: "common>/PriorityCode", templateShareable: false}'>
                                                    <items>
                                                        <core:Item key='{common>code}' text='{common>name}' />
                                                    </items>
                                                </Select>
                                            </VBox>

                                            <VBox>
                                                <!-- DISPLAY -->
                                                <ExpandableText
                                                    maxCharacters='50'
                                                    emptyIndicatorMode='{= !!%{todo>info} ? "Off" : "On" }'
                                                    text='{todo>info}'
                                                    visible='{= !%{config>/editMode} }' />
                                                <!-- EDIT -->
                                                <TextArea
                                                    width='100%'
                                                    rows='1'
                                                    growing='true'  
                                                    value='{todo>info}'
                                                    visible='{config>/editMode}' />
                                            </VBox>

                                            <OverflowToolbar style='Clear'>
                                                <ToolbarSpacer />

                                                <Button
                                                    press='onPressChangeItemStatus($event, 1)'
                                                    type='Accept'
                                                    text='Начать'
                                                    tooltip='Начать'
                                                    visible='{= %{todo>status} === 0 &amp;&amp; !%{config>/editMode} }'>
                                                    <layoutData>
                                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                                    </layoutData>
                                                </Button>

                                                <Button
                                                    press='onPressChangeItemStatus($event, 2)'
                                                    type='Accept'
                                                    icon='sap-icon://accept'
                                                    tooltip='Завершить'
                                                    visible='{= %{todo>status} === 1 &amp;&amp; !%{config>/editMode} }'>
                                                    <layoutData>
                                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                                    </layoutData>
                                                </Button>

                                                <Button
                                                    press='onPressChangeItemStatus($event, 3)'
                                                    type='Reject'
                                                    icon='sap-icon://decline'
                                                    tooltip='Отменить'
                                                    visible='{= %{todo>status} === 1 &amp;&amp; !%{config>/editMode} }'>
                                                    <layoutData>
                                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                                    </layoutData>
                                                </Button>

                                                <ObjectStatus
                                                    inverted='true'
                                                    icon='{= %{todo>status} === 2 ? "sap-icon://accept" : "sap-icon://decline"}'
                                                    text='{path: "todo>status", formatter: ".Formatter.getProgressStatusText"}' 
                                                    state='{path: "todo>status", formatter: ".Formatter.getProgressStatusState"}'
                                                    visible='{= %{todo>status} &gt; 1 &amp;&amp; !%{config>/editMode} }'>
                                                    <layoutData>
                                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                                    </layoutData>
                                                </ObjectStatus>
                                            </OverflowToolbar>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:blocks>

                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>

    </uxap:ObjectPageLayout>

</mvc:View>