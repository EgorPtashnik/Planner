<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:core='sap.ui.core'>

    <uxap:ObjectPageSection showTitle='false'>
        <uxap:subSections>
            <uxap:ObjectPageSubSection showTitle='false'>

                <uxap:blocks>
                    <Table
                        id='idTodoItems'
                        delete='onPressDeleteItem'
                        sticky='HeaderToolbar'
                        busyIndicatorDelay='0'
                        showSeparators='Inner'
                        autoPopinMode='true'
                        fixedLayout='false'
                        hiddenInPopin='{= %{state>/showDetails}.toString() === "true" ? [] : ["Low","Medium"] }'
                        items='{
                            path: "todo>items",
                            parameters: {
                                $$ownRequest: true,
                                $count: true,
                                $orderby: "createdAt desc"
                            }
                        }'>

                        <noData>
                            <IllustratedMessage
                                title='Шаги еще не добавлены'
                                description='Создайте шаг чтобы увидеть данные.'
                                illustrationType='sapIllus-NoActivities' />
                        </noData>

                        <headerToolbar>
                            <OverflowToolbar>
                                <Title text='Шаги ({state>/itemCount})' />

                                <ToolbarSpacer />

                                <Button
                                    press='onPressCreateItem'
                                    type='Ghost'
                                    text='Создать'
                                    tooltip='Создать'>
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                    </layoutData>
                                </Button>

                                <OverflowToolbarButton
                                    press='onPressDeleteCompletedItems'
                                    type='Transparent'
                                    icon='sap-icon://eraser'
                                    text='Удалить Законченные'
                                    tooltip='Удалить Законченные'>
                                    <layoutData>
                                        <OverflowToolbarLayoutData group='1' />
                                    </layoutData>
                                </OverflowToolbarButton>

                                <ToolbarSeparator>
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                    </layoutData>
                                </ToolbarSeparator>

                                <OverflowToolbarButton
                                    press='onPressToggleVisibleItems'
                                    type='Transparent'
                                    icon='{= %{state>/showCompletedItems} ? "sap-icon://show" : "sap-icon://hide" }'
                                    text='Показать законченные'
                                    tooltip='Показать законченные'>
                                    <layoutData>
                                        <OverflowToolbarLayoutData group='1' />
                                    </layoutData>
                                </OverflowToolbarButton>

                                <OverflowToolbarButton
                                    press='onPressItemSort'
                                    type='Transparent'
                                    icon='sap-icon://sort'
                                    text='Сортировка'
                                    tooltip='Сортировка'>
                                    <layoutData>
                                        <OverflowToolbarLayoutData group='1' />
                                    </layoutData>
                                </OverflowToolbarButton>

                                <OverflowToolbarToggleButton
                                    icon='sap-icon://detail-more'
                                    tooltip='Показать Детали'
                                    text='Показать Детали'
                                    pressed='{state>/showDetails}'
                                    visible='{= %{device>/system/phone} }'>
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                    </layoutData>
                                </OverflowToolbarToggleButton>

                                <SegmentedButton
                                    selectedKey='{state>/showDetails}'
                                    visible='{= !%{device>/system/phone} }'>
                                    <items>
                                        <SegmentedButtonItem
                                            key='false'
                                            icon='sap-icon://detail-less'
                                            tooltip='Скрыть Детали' />
                                        <SegmentedButtonItem
                                            key='true'
                                            icon='sap-icon://detail-more'
                                            tooltip='Показать Детали' />
                                    </items>
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                    </layoutData>
                                </SegmentedButton>
                            </OverflowToolbar>
                        </headerToolbar>

                        <columns>
                            <Column
                                width='auto'
                                importance='High' >
                                <Text text='Приоритет / Шаг'/>
                            </Column>

                            <Column
                                importance='Medium'>
                                <Text text='Начало'/>
                            </Column>

                            <Column
                                importance='Low'
                                autoPopinWidth='999'>
                                <Text text='Заметка' />
                            </Column>

                            <Column
                                width='8rem'
                                hAlign='Right'
                                importance='High'>
                                <Text text='Выполнение' />
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem
                                vAlign='{= %{device>/system/phone} ? "Top" : "Middle"}'
                                visible='{=
                                    %{state>/showCompletedItems} ||
                                    %{todo>status} === 0 || %{todo>status} === 1
                                }'>
                                <cells>
                                    <FlexBox
                                        direction='{= %{device>/system/phone} ? "Column" : "Row" }'
                                        alignItems='{= %{device>/system/phone} ? "Start" : "Center" }'>
                                        <GenericTag
                                            class='sapUiTinyMarginEnd'
                                            design='StatusIconHidden'
                                            text='{ path: "todo>priority", formatter: ".Formatter.getPriorityText" }'
                                            status='{ path: "todo>priority", formatter: ".Formatter.getPriorityState" }'
                                            visible='{= !%{device>/system/phone} }' />
                                        <ObjectIdentifier
                                            title='{todo>name}'/>
                                        <GenericTag
                                            class='sapUiTinyMarginTop'
                                            design='StatusIconHidden'
                                            text='{ path: "todo>priority", formatter: ".Formatter.getPriorityText" }'
                                            status='{ path: "todo>priority", formatter: ".Formatter.getPriorityState" }'
                                            visible='{device>/system/phone}' />
                                    </FlexBox>

                                    <Text text='{ path: "todo>startDate", formatter: ".Formatter.getDateWithoutTime" }' />

                                    <ExpandableText
                                        maxCharacters='50'
                                        emptyIndicatorMode='{= !!%{todo>info} ? "Off" : "On" }'
                                        text='{todo>info}' />

                                    <OverflowToolbar style='Clear'>
                                        <ToolbarSpacer />

                                        <Button
                                            press='onPressChangeItemStatus($event, 1)'
                                            type='Accept'
                                            text='Начать'
                                            tooltip='Начать'
                                            visible='{= %{todo>status} === 0 }'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                                            </layoutData>
                                        </Button>

                                        <Button
                                            press='onPressChangeItemStatus($event, 2)'
                                            type='Accept'
                                            icon='sap-icon://accept'
                                            tooltip='Завершить'
                                            visible='{= %{todo>status} === 1 }'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                                            </layoutData>
                                        </Button>

                                        <Button
                                            press='onPressChangeItemStatus($event, 3)'
                                            type='Reject'
                                            icon='sap-icon://decline'
                                            tooltip='Отменить'
                                            visible='{= %{todo>status} === 1 }'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                                            </layoutData>
                                        </Button>

                                        <ObjectStatus
                                            icon='{= %{todo>status} === 2 ? "sap-icon://accept" : "sap-icon://decline"}'
                                            text='{path: "todo>status", formatter: ".Formatter.getProgressStatusText"}' 
                                            state='{path: "todo>status", formatter: ".Formatter.getProgressStatusState"}'
                                            visible='{= %{todo>status} &gt; 1 }'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                                            </layoutData>
                                        </ObjectStatus>
                                    </OverflowToolbar>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </uxap:blocks>

            </uxap:ObjectPageSubSection>
        </uxap:subSections>
    </uxap:ObjectPageSection>

</core:FragmentDefinition>