<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:form='sap.ui.layout.form'
    xmlns:core='sap.ui.core'>

    <Dialog
        title='Создать Шаг'
        stretch='{device>/system/phone}'>

        <content>
            <form:SimpleForm
                layout='ColumnLayout'
                editable='true'>
                <form:content>
                    <Label text='Шаг' required='true' />
                    <Input
                        fieldGroupIds="CreateTodoItemFG"
                        width='100%'
                        value='{state>/CreateItemDialog/name}' />

                    <Label text='Приоритет' required='true' />
                    <Select
                        fieldGroupIds="CreateTodoItemFG"
                        selectedKey='{state>/CreateItemDialog/priority}'
                        items='{common>/PriorityCode}'>
                        <items>
                            <core:Item key='{common>code}' text='{common>name}' />
                        </items>
                    </Select>

                    <Label text='Начало' />
                    <DatePicker
                        dateValue='{state>/CreateItemDialog/startDate}' />

                    <Label text='Описание' />
                    <TextArea
                        rows='5'
                        value='{state>/CreateItemDialog/info}' />
                </form:content>
            </form:SimpleForm>
        </content>
    
        <buttons>
            <Button
                press='onCreateItem'
                type='Emphasized'
                text='Создать'
                tooltip='Создать' />

            <Button
                press='onPressCloseDialog'
                type='Transparent'
                text='Отменить'
                tooltip='Отменить' />

        </buttons>

    </Dialog>

</core:FragmentDefinition>