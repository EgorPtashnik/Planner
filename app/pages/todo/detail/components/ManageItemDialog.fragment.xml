<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:form='sap.ui.layout.form'
    xmlns:core='sap.ui.core'>

    <Dialog stretch='{device>/system/phone}'>

        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text='{= %{state>/ManageItemDialog/toCreate} ? "Создать" : "Редактировать"} Шаг' />
                </contentLeft>

                <contentRight>
                    <Button
                        press='onDeleteItem'
                        type='Negative'
                        icon='sap-icon://delete'
                        text='Удалить'
                        tooltip='Удалить'
                        visible='{= !%{state>/ManageItemDialog/toCreate} }' />
                </contentRight>
            </Bar>
        </customHeader>

        <content>
            <form:SimpleForm
                layout='ColumnLayout'
                editable='true'
                columnsL='1'
                columnsXL='1'>
                <form:content>

                    <Label text='Шаг' required='true' />
                    <Input
                        fieldGroupIds='ManageTodoItemFG'
                        width='100%'
                        value='{state>/ManageItemDialog/name}' />

                    <Label text='Список' required='true' visible='{= !%{state>/ManageItemDialog/toCreate} }' />
                    <ComboBox
                        id='idManageItemDialogListComboBox'
                        fieldGroupIds='ManageTodoItemFG'
                        showSecondaryValues='true'
                        visible='{= !%{state>/ManageItemDialog/toCreate} }'
                        selectedKey='{state>/ManageItemDialog/list_ID}'
                        items='{
                            path: "todo>/List",
                            parameters: {
                                $orderby: "name asc",
                                $expand: "tag"
                            }
                        }'>
                        <items>
                            <core:ListItem
                                key='{todo>ID}'
                                text='{todo>name}'
                                additionalText='{todo>tag/name}' />
                        </items>
                    </ComboBox>

                    <Label text='Приоритет' required='true' />
                    <Select
                        fieldGroupIds='ManageTodoItemFG'
                        selectedKey='{state>/ManageItemDialog/priority}'
                        items='{common>/PriorityCode}'>
                        <items>
                            <core:Item key='{common>code}' text='{common>name}' />
                        </items>
                    </Select>

                    <Label text='Начало' />
                    <DatePicker
                        dateValue='{state>/ManageItemDialog/startDate}' />

                    <Label text='Описание' />
                    <TextArea
                        rows='5'
                        value='{state>/ManageItemDialog/info}' />
                </form:content>
            </form:SimpleForm>
        </content>
    
        <buttons>
            <Button
                press='onSaveItem(%{state>/ManageItemDialog/toCreate})'
                type='Emphasized'
                text='{= %{state>/ManageItemDialog/toCreate} ? "Создать" : "Сохранить" }'
                tooltip='{= %{state>/ManageItemDialog/toCreate} ? "Создать" : "Сохранить" }' />

            <Button
                press='onPressCloseDialog'
                type='Transparent'
                text='Отменить'
                tooltip='Отменить' />
        </buttons>

    </Dialog>

</core:FragmentDefinition>