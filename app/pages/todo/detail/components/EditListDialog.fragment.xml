<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:form='sap.ui.layout.form'
    xmlns:core='sap.ui.core'>

    <Dialog
        title='Редактировать Список'
        stretch='{device>/system/phone}'>

        <content>
            <form:SimpleForm
                layout='ColumnLayout'
                editable='true'>
                <form:content>
                    <Label text='Имя' />
                    <Input
                        width='100%'
                        value='{state>/EditListDialog/name}' />

                    <Label text='Приоритет' />
                    <Select
                        selectedKey='{state>/EditListDialog/priority}'
                        items='{common>/PriorityCode}'>
                        <items>
                            <core:Item key='{common>code}' text='{common>name}' />
                        </items>
                    </Select>

                    <Label text='Тег' />
                    <ComboBox
                        id='idEditListDialogTagComboBox'
                        selectedKey='{state>/EditListDialog/tag_ID}'
                        items='{todo>/ListTag}'>
                        <items>
                            <core:Item key='{todo>ID}' text='{todo>name}' />
                        </items>
                    </ComboBox>

                    <Label text='Описание' />
                    <TextArea
                        rows='5'
                        growing='true'
                        growingMaxLines='20'
                        value='{state>/EditListDialog/info}' />
                </form:content>
            </form:SimpleForm>
        </content>
    
        <buttons>
            <Button
                press='onSaveList'
                type='Emphasized'
                text='Сохранить'
                tooltip='Сохранить' />

            <Button
                press='onPressCloseDialog'
                type='Transparent'
                text='Отменить'
                tooltip='Отменить' />

        </buttons>

    </Dialog>

</core:FragmentDefinition>