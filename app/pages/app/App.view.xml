<mvc:View
    xmlns='sap.tnt'
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    displayBlock='true'
    height='100%'
    busyIndicatorDelay='0'
	controllerName='planner.pages.app.App'>

    <ToolPage sideExpanded="{/sideNavExpanded}">

        <header>
            <core:Fragment fragmentName='planner.pages.app.components.Header' type='XML' />
        </header>

        <mainContents>
            <f:FlexibleColumnLayout
                id='app'
                stateChange='onFCLStateChange'
                layout='{/layout}' />
        </mainContents>

        <sideContent>
            <core:Fragment fragmentName='planner.pages.app.components.SideContent' type='XML' />
        </sideContent>

    </ToolPage>
     
</mvc:View>