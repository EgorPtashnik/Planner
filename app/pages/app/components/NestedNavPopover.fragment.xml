<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:card='sap.f.cards'
    xmlns:f='sap.f'
    xmlns:core='sap.ui.core'>

    <Popover
        class='sapUiContentPadding'
        showHeader='false'
        placement='Bottom'
        contentWidth='40%'>
        <content>
            <f:GridContainer
                items='{state>/NestedNavPopover/items}'>
                    <f:Card
                        press='onSelectNavItem(%{state>key})'
                        height='100%'>
                        <f:header>
                            <card:Header
                                title='{state>text}'
                                iconSrc='{state>icon}'
                                iconSize='XS' />
                        </f:header>

                        <f:layoutData>
                            <f:GridContainerItemLayoutData
                                rows='2'
                                columns='2' />
                        </f:layoutData>
                    </f:Card>
            </f:GridContainer>
        </content>
    </Popover>

</core:FragmentDefinition>