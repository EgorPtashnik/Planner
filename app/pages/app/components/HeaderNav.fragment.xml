<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <IconTabHeader
        mode='Inline'
        backgroundDesign='Transparent'
        select='onSelectNavItem'
        visible='{= !%{device>/system/phone} }'
        selectedKey='{/selectedRoute}'>
        <items>
            <IconTabSeparator />

            <IconTabFilter
                icon='sap-icon://home'
                text='Главная'
                key='home' />
            <IconTabSeparator />

            <IconTabFilter
                icon='sap-icon://activities'
                text='Мои Дела'
                key='todoMaster' />
            <IconTabSeparator />

            <IconTabFilter
                icon='sap-icon://physical-activity'
                text='Тренировки'
                key='gym' />
            <IconTabSeparator />

            <IconTabFilter
                icon='sap-icon://shield'
                text='ArmA'
                key='arma' />
            <IconTabSeparator />
        </items>
    </IconTabHeader>

</core:FragmentDefinition>
