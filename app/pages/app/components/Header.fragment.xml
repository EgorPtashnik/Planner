<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core">

    <tnt:ToolHeader>
        <tnt:content>
            <ToggleButton
                class='HeaderBtn'
                icon="sap-icon://menu2"
                pressed='{/sideNavExpanded}'
                visible='{device>/system/phone}' >
                <layoutData>
                    <OverflowToolbarLayoutData priority="NeverOverflow" />
                </layoutData>
            </ToggleButton>

            <Image
                class="sapUiSmallMarginBegin"
                height="2.5rem"
                mode="Image"
                src="./icons/512.png"
                visible="{= !%{device>/system/phone} }" />

            <Title titleStyle="{= %{device>/system/phone} ? 'H5' : 'H4' }" text="PlanneR 2.0" />

            <ToolbarSeparator />
            
            <core:Fragment fragmentName='planner.pages.app.components.HeaderNav' type='XML' />

            <ToolbarSpacer width="{= %{device>/system/phone} ? '' : 'auto' }" />

            <Button
                press='onPressToggleDarkMode'
                class='HeaderBtn'
                icon='{= %{/darkMode} ? "sap-icon://dark-mode" : "sap-icon://light-mode" }'
                tooltip='{= %{/darkMode} ? "Светлая Тема" : "Тёмная Тема" }' />

            <Button
                press='onPressDatabaseMenu'
                class='HeaderBtn'
                ariaHasPopup='Menu'
                busyIndicatorSize='Small'
                busyIndicatorDelay='0'
                icon='sap-icon://database'
                tooltip='База Данных' />

        </tnt:content>
    </tnt:ToolHeader>

</core:FragmentDefinition>
