<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:form='sap.ui.layout.form'
    xmlns:core='sap.ui.core'>

    <Dialog
        title='Новая Функция'
        stretch='{device>/system/phone}'>
        
        <content>
            <form:SimpleForm
                layout='ColumnLayout'
                editable='true'
                columnsM='1'
                columnsL='1'
                columnsXL='1'>
                <form:content>
                    <Label text='Название' required='true' />
                    <Input width='100%' value='{state>/CreateSqfCommandDialog/name}' />

                    <Label text='Тип' />
                    <Input editable='false' value='{state>/CreateSqfCommandDialog/type}' />

                    <Label text='Источник' />
                    <Input editable='false' value='{state>/CreateSqfCommandDialog/source}' />

                    <Label text='Описание' />
                    <TextArea
                        rows='5'
                        value='{state>/CreateSqfCommandDialog/info}' />

                    <Label text='Теги' />
                    <MultiComboBox
                        id='idCreateSqfCommandDialogTagComboBox'
                        selectedKeys='{state>/CreateSqfCommandDialog/tags}'
                        items='{arma>/SqfTag}'>
                        <items>
                            <core:Item key='{arma>ID}' text='{arma>name}' />
                        </items>
                    </MultiComboBox>
                </form:content>
            </form:SimpleForm>
        </content>

        <buttons>
            <Button
                press='onCreateSqfCommand'
                type='Emphasized'
                text='Создать'
                tooltip='Создать' />
            <Button
                press='onPressCloseDialog'
                type='Transparent'
                text='Закрыть'
                tooltip='Закрыть' />
        </buttons>

    </Dialog>

</core:FragmentDefinition>