<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:fb='sap.ui.comp.filterbar'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    busyIndicatorDelay='0'
	controllerName='planner.pages.arma.sqf.master.SQFMaster'>

    <f:DynamicPage headerExpanded='false'>



        <!-- HEADER -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>

                    <Title text='ArmA: SQF Документация' />

                </f:heading>
            </f:DynamicPageTitle>
        </f:title>



        <!-- HEADER CONTENT -->
        <f:header>
            <f:DynamicPageHeader>
                <fb:FilterBar showGoOnFB="false" useToolbar="false">
                    <fb:filterGroupItems>

                        <fb:FilterGroupItem name="fbSearch" label="Поиск" groupName="basic" visibleInFilterBar="true">
                            <fb:control>
                                <SearchField change='onChangeSqfCommandSearch' />
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem name="fbType" label="Тип" groupName="basic" visibleInFilterBar="true">
                            <fb:control>
                                <ComboBox
                                    selectionChange='onChangeSqfCommandFilter'
                                    selectedKey='{config>/filterBar/type}'
                                    items='{arma>/SqfCommandType}'>
                                    <items>
                                        <core:Item key='{arma>code}' text='{arma>name}' />
                                    </items>
                                </ComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem name="fbSource" label="Источник" groupName="basic" visibleInFilterBar="true">
                            <fb:control>
                                <ComboBox
                                    selectionChange='onChangeSqfCommandFilter'
                                    selectedKey='{config>/filterBar/source}'
                                    items='{arma>/SqfCommandSource}'>
                                    <items>
                                        <core:Item key='{arma>code}' text='{arma>name}' />
                                    </items>
                                </ComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem name="fbTags" label="Теги" groupName="basic" visibleInFilterBar="true">
                            <fb:control>
                                <MultiComboBox
                                    selectionFinish='onChangeSqfCommandFilter'
                                    selectedKeys='{config>/filterBar/tags}'
                                    items='{arma>/SqfTag}'>
                                    <items>
                                        <core:Item key='{arma>ID}' text='{arma>name}' />
                                    </items>
                                </MultiComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>

                    </fb:filterGroupItems>
                </fb:FilterBar>
            </f:DynamicPageHeader>
        </f:header>



        <!-- FUNCTIONS LIST -->
        <f:content>
            <Table
                id='idSqfCommandsList'
                sticky='HeaderToolbar'
                showSeparators='Inner'
                autoPopinMode='true'
                hiddenInPopin='{= %{config>/showSqfCommandsDetails}.toString() === "true" ? [] : ["Low","Medium"]}'
                items="{
                    path: 'arma>/SqfCommand',
                    parameters: {
                        $count: true,
                        $expand: 'type,source'
                    }
                }">

                <noData>
                    <IllustratedMessage
                        title='Функции еще не добавлены'
                        description='Создайте функцию чтобы увидеть данные.'
                        illustrationType='sapIllus-NoData' />
                </noData>

                <headerToolbar>
                    <OverflowToolbar design='Solid'>
                        <Title text='Функции ({config>/sqfCommandsCount})' />

                        <ToolbarSpacer />

                        <Button
                            press='onPressCreateSqfCommand'
                            type='Ghost'
                            text='Создать'
                            tooltip='Создать'>
                            <layoutData>
                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                            </layoutData>
                        </Button>

                        <OverflowToolbarButton
                            press='onPressManageSqfTags'
                            icon='sap-icon://tags'
                            text='Изменить Теги'
                            tooltip='Изменить Теги'>
                            <layoutData>
                                <OverflowToolbarLayoutData group='1' />
                            </layoutData>
                        </OverflowToolbarButton>

                        <OverflowToolbarToggleButton
                            icon='sap-icon://detail-more'
                            tooltip='Показать Детали'
                            text='Показать Детали'
                            visible='{device>/system/phone}'
                            pressed='{config>/showSqfCommandsDetails}'>
                            <layoutData>
                                <OverflowToolbarLayoutData group='1' />
                            </layoutData>
                        </OverflowToolbarToggleButton>

                        <SegmentedButton
                            selectedKey='{path: "config>/showSqfCommandsDetails", targetType: "Boolean" }'
                            visible='{= !%{device>/system/phone} }'>
                            <items>
                                <SegmentedButtonItem
                                    key='false'
                                    icon='sap-icon://detail-less'
                                    tooltip='Скрыть Детали' />
                                <SegmentedButtonItem
                                    key='true'
                                    icon='sap-icon://detail-more'
                                    tooltip='Показать Детали' />
                            </items>
                            <layoutData>
                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                            </layoutData>
                        </SegmentedButton>
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column width='auto'>
                        <Text text='Имя' />
                    </Column>
                    <Column width='8rem' popinDisplay='WithoutHeader'>
                        <Text text='Тип' />
                    </Column>
                    <Column importance='Low' popinDisplay='WithoutHeader' autoPopinWidth='999'>
                        <Text text='Описание' />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem
                        vAlign='Top'
                        press='onPressSqfCommandItem'
                        navigated='{= %{/detailID} === %{arma>name} }'
                        highlight='{= %{/detailID} === %{arma>name} ? "Information" : "None" }'
                        type='{= %{/detailID} === %{arma>name} ? "Active" : "Navigation" }'>
                        <cells>

                            <VBox>
                                <ObjectIdentifier title='{arma>name}' />
                                <ObjectStatus
                                    state='{=
                                        %{arma>source/code} === 1 ? "Information" :
                                        %{arma>source/code} === 2 ? "Warning" :
                                        "Error"
                                    }'
                                    text='{arma>source/name}' />
                            </VBox>

                            <ObjectStatus
                                inverted='true'
                                text='{arma>type/name}' />

                            <FormattedText htmlText='{arma>info}' />
                            
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>
        </f:content>

    </f:DynamicPage>

</mvc:View>