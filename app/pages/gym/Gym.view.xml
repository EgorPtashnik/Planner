<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    busyIndicatorDelay='0'
	controllerName='planner.pages.gym.Gym'>

    <f:DynamicPage>

        <!-- HEADER -->
        <f:title>
            <core:Fragment fragmentName='planner.pages.gym.components.Header' type='XML' />
        </f:title>

        <!-- Information Message -->
        <f:content>
            <VBox alignItems='Center' justifyContent='Center' fitContainer='true'>
                <IllustratedMessage
                    decorative='true'
                    enableDefaultTitleAndDescription='false'
                    illustrationType='sapIllus-EmptyPlanningCalendar'
                    illustrationSize='Large'
                    title='Сумма: {state>/totalCost} BYN'>
                    <additionalContent>
                        <HBox justifyContent='SpaceBetween'>
                            <Button
                                press='onPressAddTraining'
                                width='100%'
                                type='Emphasized'
                                text='Записать Тренировку'
                                tooltip='Записать Тренировку'>
                                <layoutData>
                                    <FlexItemData growFactor='1' />
                                </layoutData>
                            </Button>
                        </HBox>
                    </additionalContent>
                </IllustratedMessage>
            </VBox>
        </f:content>

    </f:DynamicPage>

</mvc:View>