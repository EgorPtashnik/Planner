<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    busyIndicatorDelay='0'
	controllerName='planner.pages.gym.Gym'>

    <f:DynamicPage
        class='sapUiResponsiveContentPadding'
        toggleHeaderOnTitleClick='false'
        preserveHeaderStateOnScroll='true'>

        <f:title>
            <core:Fragment fragmentName='planner.pages.gym.components.Header' />
        </f:title>

        <f:header>
            <core:Fragment fragmentName='planner.pages.gym.components.Summary' />
        </f:header>

        <f:content>
            <core:Fragment fragmentName='planner.pages.gym.components.Calendar' type='XML' />
        </f:content>

    </f:DynamicPage>

</mvc:View>