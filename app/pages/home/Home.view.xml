<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
	controllerName='planner.pages.home.Home'>

    <f:DynamicPage>

        <f:content>
            <f:GridContainer>
                <f:items>
                    <core:Fragment fragmentName='planner.pages.home.components.StartedTodoTile' />
                    <core:Fragment fragmentName='planner.pages.home.components.TrainingTile' />
                </f:items>
				<f:layoutS>
					<f:GridContainerSettings maxColumnSize='10rem' gap="0px" />
				</f:layoutS>
            </f:GridContainer>
        </f:content>

    </f:DynamicPage>

</mvc:View>