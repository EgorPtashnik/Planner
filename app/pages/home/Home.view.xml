<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
	controllerName='planner.pages.home.Home'>

    <f:DynamicPage id='idHomePage'>

        <f:content>
            <f:GridContainer class='tileContainer'>
                <f:items>
                    <core:Fragment fragmentName='planner.pages.home.components.TrainingTile' />
                    <core:Fragment fragmentName='planner.pages.home.components.StartedTodoTile' />
                </f:items>
            </f:GridContainer>
        </f:content>

    </f:DynamicPage>

</mvc:View>