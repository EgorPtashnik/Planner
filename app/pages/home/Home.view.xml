<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
	controllerName='planner.pages.home.Home'>

    <f:DynamicPage>

        <f:title>
            <core:Fragment fragmentName='planner.pages.home.components.Header' />
        </f:title>

        <f:content>
            <f:GridContainer>
                <f:items>
                    <core:Fragment fragmentName='planner.pages.home.components.CurrentActivitiesTile' />
                </f:items>
            </f:GridContainer>
        </f:content>

    </f:DynamicPage>

</mvc:View>