<mvc:View
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    busyIndicatorDelay='0'
	controllerName='planner.controller.gym.Gym'>

    <f:DynamicPage>

        <!-- HEADER -->
        <f:title>
            <core:Fragment fragmentName='planner.view.gym.component.Header' type='XML' />
        </f:title>

        <!-- Information Message -->
        <f:content>
            <core:Fragment fragmentName='planner.view.gym.component.Info' type='XML' />
        </f:content>

    </f:DynamicPage>

</mvc:View>