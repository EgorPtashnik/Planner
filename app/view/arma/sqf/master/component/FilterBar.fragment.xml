<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:fb='sap.ui.comp.filterbar'
    xmlns:core="sap.ui.core">
    
    <f:DynamicPageHeader>

        <fb:FilterBar showGoOnFB="false" useToolbar="false">
            <fb:filterGroupItems>

                <fb:FilterGroupItem name="fbSearch" label="Поиск" groupName="basic" visibleInFilterBar="true">
                    <fb:control>
                        <SearchField />
                    </fb:control>
                </fb:FilterGroupItem>

                <fb:FilterGroupItem name="fbType" label="Тип" groupName="basic" visibleInFilterBar="true">
                    <fb:control>
                        <ComboBox />
                    </fb:control>
                </fb:FilterGroupItem>

                <fb:FilterGroupItem name="fbSource" label="Источник" groupName="basic" visibleInFilterBar="true">
                    <fb:control>
                        <ComboBox />
                    </fb:control>
                </fb:FilterGroupItem>

                <fb:FilterGroupItem name="fbTags" label="Теги" groupName="basic" visibleInFilterBar="true">
                    <fb:control>
                        <MultiComboBox />
                    </fb:control>
                </fb:FilterGroupItem>

            </fb:filterGroupItems>
        </fb:FilterBar>

    </f:DynamicPageHeader>

</core:FragmentDefinition>