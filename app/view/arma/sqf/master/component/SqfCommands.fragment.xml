<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:core='sap.ui.core'>

    <uxap:ObjectPageSection showTitle='false'>
        <uxap:subSections>
            <uxap:ObjectPageSubSection>
                <uxap:blocks>

                    <Table
                        id='idSqfCommandsList'
                        sticky='HeaderToolbar'
                        showSeparators='Inner'
                        fixedLayout='false'
                        items="{
                            path: 'arma>/SqfCommand',
                            parameters: {
                                $count: true,
                                $expand: 'type,source'
                            }
                        }">

                        <noData>
                            <IllustratedMessage
                                title='Функции еще не добавлены'
                                description='Создайте функцию чтобы увидеть данные.'
                                illustrationType='sapIllus-NoData' />
                        </noData>

                        <headerToolbar>
                            <OverflowToolbar design='Solid'>
                                <Title text='Функции ({config>/sqfCommandsCount})' />

                                <ToolbarSpacer />

                                <Button
                                    press='onPressCreateSqfCommand'
                                    type='Ghost'
                                    text='Создать'
                                    tooltip='Создать' />
                            </OverflowToolbar>
                        </headerToolbar>

                        <columns>
                            <Column>
                                <Text text='Функция' />
                            </Column>
                            <Column>
                                <Text text='Тип' />
                            </Column>
                            <Column>
                                <Text text='Описание' />
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem>
                                <cells>

                                    <HBox>
                                        <ObjectIdentifier title='{arma>name}' />
                                        <GenericTag text='{arma>source/name}' />
                                    </HBox>

                                    <ObjectStatus
                                        inverted='true'
                                        text='{arma>type/name}' />

                                    <Text text='{arma>info}' />
                                    
                                </cells>
                            </ColumnListItem>
                        </items>

                    </Table>

                </uxap:blocks>
            </uxap:ObjectPageSubSection>
        </uxap:subSections>
    </uxap:ObjectPageSection>
</core:FragmentDefinition>