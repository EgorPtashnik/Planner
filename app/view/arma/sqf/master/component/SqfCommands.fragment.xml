<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:core='sap.ui.core'>

    <Table
        id='idSqfCommandsList'
        inset='true'
        sticky='HeaderToolbar'
        showSeparators='Inner'
        autoPopinMode='true'
        hiddenInPopin='{= %{config>/showSqfCommandsDetails}.toString() === "true" ? [] : ["Low","Medium"]}'
        items="{
            path: 'arma>/SqfCommand',
            parameters: {
                $count: true,
                $expand: 'type,source'
            }
        }">

        <noData>
            <IllustratedMessage
                title='Функции еще не добавлены'
                description='Создайте функцию чтобы увидеть данные.'
                illustrationType='sapIllus-NoData' />
        </noData>

        <headerToolbar>
            <OverflowToolbar design='Solid'>
                <Title text='Функции ({config>/sqfCommandsCount})' />

                <ToolbarSpacer />

                <Button
                    press='onPressCreateSqfCommand'
                    type='Emphasized'
                    text='Создать Функцию'
                    tooltip='Создать Функцию'>
                    <layoutData>
                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                    </layoutData>
                </Button>

                <ToolbarSeparator visible='{= !%{device>/system/phone} }' />

                <ToggleButton
                    type='Ghost'
                    icon='sap-icon://detail-more'
                    tooltip='Показать Детали'
                    text='Показать Детали'
                    visible='{device>/system/phone}'
                    pressed='{config>/showSqfCommandsDetails}' />

                <SegmentedButton
                    selectedKey='{path: "config>/showSqfCommandsDetails", targetType: "Boolean" }'
                    visible='{= !%{device>/system/phone} }'>
                    <items>
                        <SegmentedButtonItem
                            key='false'
                            icon='sap-icon://detail-less'
                            tooltip='Скрыть Детали' />
                        <SegmentedButtonItem
                            key='true'
                            icon='sap-icon://detail-more'
                            tooltip='Показать Детали' />
                    </items>
                    <layoutData>
                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                    </layoutData>
                </SegmentedButton>
            </OverflowToolbar>
        </headerToolbar>

        <columns>
            <Column width='auto'>
                <Text text='Функция' />
            </Column>
            <Column width='8rem' popinDisplay='WithoutHeader'>
                <Text text='Тип' />
            </Column>
            <Column importance='Low' popinDisplay='WithoutHeader' autoPopinWidth='999'>
                <Text text='Описание' />
            </Column>
        </columns>

        <items>
            <ColumnListItem
                vAlign='Top'
                press='onPressSqfCommandItem'
                navigated='{= %{/detailID} === %{arma>name} }'
                highlight='{= %{/detailID} === %{arma>name} ? "Information" : "None" }'
                type='{= %{/detailID} === %{arma>name} ? "Active" : "Navigation" }'>
                <cells>

                    <VBox>
                        <ObjectIdentifier title='{arma>name}' />
                        <ObjectStatus
                            state='{=
                                %{arma>source/code} === 1 ? "Information" :
                                %{arma>source/code} === 2 ? "Warning" :
                                "Error"
                            }'
                            text='{arma>source/name}' />
                    </VBox>

                    <ObjectStatus
                        inverted='true'
                        text='{arma>type/name}' />

                    <FormattedText htmlText='{arma>info}' />
                    
                </cells>
            </ColumnListItem>
        </items>

    </Table>

</core:FragmentDefinition>