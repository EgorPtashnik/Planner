    xmlns:core='sap.ui.core'
    busyIndicatorDelay='0'
	controllerName='planner.controller.arma.sqf.master.SQFMaster'>

    <f:DynamicPage
        headerExpanded='false'>

        <f:title>
            <core:Fragment fragmentName='planner.view.arma.sqf.master.component.Header' type='XML' />
        </f:title>

        <f:header>
            <core:Fragment fragmentName='planner.view.arma.sqf.master.component.FilterBar' type='XML' />
        </f:header>

        <f:content>
            <core:Fragment fragmentName='planner.view.arma.sqf.master.component.Table' type='XML' />
        </f:content>

    </f:DynamicPage>

</mvc:View>