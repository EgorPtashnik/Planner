<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:uxap='sap.uxap'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    busyIndicatorDelay='0'
	controllerName='planner.controller.arma.sqf.detail.SQFDetail'>

    <uxap:ObjectPageLayout upperCaseAnchorBar='false'>

        <!-- HEADER -->
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>

                <uxap:breadcrumbs>
                    <Breadcrumbs currentLocationText='{arma>name}'>
                        <links>
                            <Link press='onPressClosePage' text='Функции' />
                        </links>
                    </Breadcrumbs>
                </uxap:breadcrumbs>

                <uxap:navigationActions>
                    <Button
                        press='onToggleFullScreen(%{/layout} === "MidColumnFullScreen")'
                        icon='{= %{/layout} === "MidColumnFullScreen" ? "sap-icon://exit-full-screen" : "sap-icon://full-screen" }'
                        tooltip='Полный Экран'
                        visible='{= !%{/isOnlyOneColumn} }' />

                    <Button
                        press='onPressClosePage'
                        icon='sap-icon://decline'
                        visible='{= !%{/layout}.includes("One") &amp;&amp; !%{/layout}.includes("Three") }' />
                </uxap:navigationActions>

                <uxap:actions>
                    <ToggleButton
                        press='onToggleEditMode'
                        type='Emphasized'
                        tooltip='Режим редактирования'
                        icon='sap-icon://edit'
                        pressed='{config>/editMode}'>
                        <layoutData>
                            <OverflowToolbarLayoutData priority='NeverOverflow' />
                        </layoutData>
                    </ToggleButton>

                    <OverflowToolbarButton
                        press='onPressSourceCode'
                        icon='sap-icon://source-code'
                        text='Исходный Код'
                        tooltip='Исходный Код' />

                    <Button
                        press='onPressDeleteSqfCommand'
                        text='Удалить'
                        tooltip='Удалить'
                        icon='sap-icon://delete'
                        type='Negative'>
                        <layoutData>
                            <OverflowToolbarLayoutData priority='AlwaysOverflow' />
                        </layoutData>
                    </Button>
                </uxap:actions>

                <uxap:snappedHeading>
                    <Title text='{arma>name}' />
                </uxap:snappedHeading>

                <uxap:expandedHeading>
                    <VBox>
                        <Title text='{arma>name}' />
                        <HBox>
                            <GenericTag
                                visible='{= !%{config>/editMode} }'
                                design='StatusIconHidden'
                                status='{=
                                    %{arma>source/code} === 1 ? "Information" :
                                    %{arma>source/code} === 2 ? "Warning" :
                                    "Error"
                                }'
                                text='{arma>source/name}' />
                            <Select
                                visible='{config>/editMode}'
                                selectedKey='{arma>source_code}'
                                items='{arma>/SqfCommandSource}'>
                                <items>
                                    <core:Item key='{arma>code}' text='{arma>name}' />
                                </items>
                            </Select>
                            <GenericTag
                                visible='{= !%{config>/editMode} }'
                                class='sapUiTinyMarginBegin' text='{arma>type/name}' />
                            <Select
                                visible='{config>/editMode}'
                                selectedKey='{arma>type_code}'
                                items='{arma>/SqfCommandType}'>
                                <items>
                                    <core:Item key='{arma>code}' text='{arma>name}' />
                                </items>
                            </Select>
                        </HBox>
                    </VBox>
                </uxap:expandedHeading>

                <uxap:expandedContent>
                    <ObjectStatus
                        title='Обновлено'
                        text='{arma>modifiedAt}'
                        visible='{= !%{config>/editMode} }' />
                </uxap:expandedContent>

            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>



        <!-- HEADER CONTENT -->
        <uxap:headerContent>

            <!-- DISPLAY MODE -->
            <VBox visible='{= !%{config>/editMode} }'>
                <FormattedText
                    htmlText='{= %{arma>info} || "Нет описания" }' />

                <Tokenizer
                    id='idTagsContainer'
                    width='100%'
                    tokens='{
                        path: "arma>tags",
                        parameters: { $$ownRequest: true, $expand: "tag" }
                    }'>
                    <tokens>
                        <Token text='{arma>tag/name}' editable='false' />
                    </tokens>
                </Tokenizer>
            </VBox>

            <!-- EDIT MODE -->
            <VBox visible='{config>/editMode}'>
                <TextArea
                    width='100%'
                    rows='5'
                    value='{arma>info}' />

                <MultiComboBox
                    selectedKeys='{config>/selectedTags}'
                    items='{arma>/SqfTag}'>
                    <items>
                        <core:Item key='{arma>ID}' text='{arma>name}' />
                    </items>
                </MultiComboBox>
            </VBox>

        </uxap:headerContent>


        <!-- SECTIONS -->
        <uxap:sections>

            <!-- SYNTAX -->
            <uxap:ObjectPageSection title='Синтаксис' showTitle='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection showTitle='false'>

                        <uxap:blocks>
                            <Panel>

                                <headerToolbar>
                                    <OverflowToolbar class='sapMTBHeader-CTX'>
                                        <Title text='Синтаксис' />
                                        <Button
                                            press='onPressCopy(%{arma>syntax})'
                                            icon='sap-icon://copy' />
                                    </OverflowToolbar>
                                </headerToolbar>

                                <content>
                                    <VBox>
                                        <!-- DISPLAY MODE -->
                                        <FormattedText
                                            htmlText='&lt;code&gt;{arma>syntax}&lt;/code&gt;'
                                            visible='{= !%{config>/editMode} }' />
                                        <!-- EDIT MODE -->
                                        <TextArea
                                            width='100%'
                                            rows='5'
                                            value='{arma>syntax}'
                                            visible='{config>/editMode}' />
                                    </VBox>
                                </content>

                            </Panel>
                        </uxap:blocks>

                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>



            <!-- PARAMETERS -->
            <uxap:ObjectPageSection title='Параметры' showTitle='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection titleUppercase='false'>

                        <uxap:blocks>
                            <Table
                                id='idSqfCommandParamsList'
                                delete='onPressDeleteParameter'
                                alternateRowColors='true'
                                showSeparators='Inner'
                                autoPopinMode='true'
                                hiddenInPopin='{= %{config>/showSqfCommandParamsDetails}.toString() === "true" ? [] : ["Low","Medium"]}'
                                mode='{= %{config>/editMode} ? "Delete" : "None" }'
                                items='{
                                    path: "arma>params",
                                    parameters: {
                                        $expand: "type,command",
                                        $orderby: "sort asc",
                                        $$ownRequest: true
                                    }
                                }'>

                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text='Параметры' />

                                        <ToolbarSpacer />

                                        <Button
                                            press='onPressAddParameter'
                                            type='Ghost'
                                            text='Добавить'
                                            tooltip='Добавить'
                                            visible='{config>/editMode}' />

                                        <ToolbarSeparator visible='{config>/editMode}' />

                                        <OverflowToolbarToggleButton
                                            icon='sap-icon://detail-more'
                                            tooltip='Показать Детали'
                                            text='Показать Детали'
                                            visible='{device>/system/phone}'
                                            pressed='{config>/showSqfCommandParamsDetails}' />

                                        <SegmentedButton
                                            selectedKey='{path: "config>/showSqfCommandParamsDetails", targetType: "Boolean" }'
                                            visible='{= !%{device>/system/phone} }'>
                                            <items>
                                                <SegmentedButtonItem
                                                    key='false'
                                                    icon='sap-icon://detail-less'
                                                    tooltip='Скрыть Детали' />
                                                <SegmentedButtonItem
                                                    key='true'
                                                    icon='sap-icon://detail-more'
                                                    tooltip='Показать Детали' />
                                            </items>
                                            <layoutData>
                                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                                            </layoutData>
                                        </SegmentedButton>
                                    </OverflowToolbar>
                                </headerToolbar>

                                <columns>
                                    <Column width='2rem' hAlign='Center' importance='High' visible='{config>/editMode}'>
                                        <Text text='№' />
                                    </Column>
                                    <Column width='8rem' importance='High' popinDisplay='Inline'>
                                        <Text text='Параметр' />
                                    </Column>
                                    <Column width='8rem' popinDisplay='Inline'>
                                        <Text text='Тип {= %{config>/editMode} ? "/ Массив" : ""}' />
                                    </Column>
                                    <Column width='10rem' popinDisplay='Inline' importance='Low'>
                                        <Text text='По Умолчанию' />
                                    </Column>
                                    <Column importance='Low' autoPopinWidth='999' popinDisplay='WithoutHeader'>
                                        <Text text='Описание' />
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem vAlign='Top'>
                                        <cells>
                                            <Input value='{arma>sort}' />
                                            <VBox>
                                                <!-- DISPLAY MODE -->
                                                <ObjectIdentifier title='{arma>name}' text='{= !!%{arma>defaultValue} ? "Опциональный" : "" }' visible='{= !%{config>/editMode} }' />
                                                <!-- EDIT MODE -->
                                                <Input value='{arma>name}' visible='{config>/editMode}' />
                                            </VBox>

                                            <!-- EDIT MODE -->
                                            <VBox>
                                                <!-- DISPLAY MODE -->
                                                <Link text='{= %{arma>isArray} ? "Array&lt;" + %{arma>type/name} + "&gt;" : %{arma>type/name} }' visible='{= !%{config>/editMode} }' />
                                                <!-- EDIT MODE -->
                                                <HBox visible='{config>/editMode}'>
                                                    <ComboBox
                                                        selectedKey='{arma>type_code}'
                                                        items='{path: "arma>/SqfType", templateShareable: "false"}'>
                                                        <items>
                                                            <core:Item key='{arma>code}' text='{arma>name}' />
                                                        </items>
                                                    </ComboBox>
                                                    <CheckBox selected='{arma>isArray}' />
                                                </HBox>
                                            </VBox>

                                            <VBox>
                                                <!-- DISPLAY MODE -->
                                                <Text text='{arma>defaultValue}' emptyIndicatorMode='{= %{arma>defaultValue} ? "Off" : "On" }' visible='{= !%{config>/editMode} }' />
                                                <!-- EDIT MODE -->
                                                <Input value='{arma>defaultValue}' visible='{config>/editMode}' />
                                            </VBox>

                                            <VBox>
                                                <!-- DISPLAY MODE -->
                                                <FormattedText htmlText='{arma>info}' visible='{= !%{config>/editMode} }' />
                                                <!-- EDIT MODE -->
                                                <TextArea cols='100' rows='5' value='{arma>info}' visible='{config>/editMode}' />
                                            </VBox>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:blocks>

                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>



            <!-- EXAMPLES \ NOTES -->
            <uxap:ObjectPageSection title='Примеры / Заметки' showTitle='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection showTitle='false'>

                        <uxap:blocks>
                            <List
                                id='idSqfCommandExamplesList'
                                delete='onPressDeleteExample'
                                showSeparators='Inner'
                                mode='{= %{config>/editMode} ? "Delete" : "None" }'
                                items='{
                                    path: "arma>examples",
                                    parameters: {
                                        $$ownRequest: true
                                    }
                                }'>

                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text='Примеры / Заметки' />

                                        <ToolbarSpacer />
                                        
                                        <Button
                                            press='onPressAddExample'
                                            type='Ghost'
                                            text='Добавить'
                                            tooltip='Добавить'
                                            visible='{config>/editMode}' />
                                    </OverflowToolbar>
                                </headerToolbar>

                                <items>
                                    <CustomListItem>
                                        <VBox class='sapUiSmallMargin'>
                                            <FormattedText htmlText='{arma>text}' visible='{= !%{config>/editMode} }' />
                                            <TextArea width='100%' rows='10' value='{arma>text}' visible='{config>/editMode}' />
                                        </VBox>
                                    </CustomListItem>
                                </items>

                            </List>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>


            
            <!-- RELATED -->
            <uxap:ObjectPageSection title='Дополнительно' showTitle='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection showTitle='false'>

                        <uxap:blocks>
                            <List
                                id='idSqfCommandRelatedList'
                                delete='onPressDeleteRelated'
                                showSeparators='Inner'
                                mode='{= %{config>/editMode} ? "Delete" : "None" }'
                                items='{
                                    path: "arma>related"
                                }'>
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text='Дополнительно' />

                                        <ToolbarSpacer />

                                        <Button
                                            press='onPressAddRelated'
                                            type='Ghost'
                                            text='Добавить'
                                            tooltip='Добавить'
                                            visible='{config>/editMode}' />
                                    </OverflowToolbar>
                                </headerToolbar>

                                <items>
                                    <CustomListItem
                                        press='onPressRelatedItem'
                                        type='{= %{config>/editMode} ? "Inactive" : "Navigation" }'>
                                        <VBox class='sapUiSmallMargin'>
                                            <Link
                                                press='onPressRelatedItem'
                                                text='{arma>related}'
                                                visible='{= !%{config>/editMode} }' />
                                            <ComboBox
                                                selectedKey='{arma>related}'
                                                visible='{config>/editMode}'
                                                items='{
                                                    path: "arma>/SqfCommand",
                                                    templateShareable: false
                                                }'>
                                                <items>
                                                    <core:Item key='{arma>name}' text='{arma>name}' />
                                                </items>
                                            </ComboBox>
                                        </VBox>
                                    </CustomListItem>
                                </items>
                            </List>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>

    </uxap:ObjectPageLayout>

</mvc:View>