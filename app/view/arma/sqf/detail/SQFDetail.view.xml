<mvc:View
    xmlns:f='sap.f'
    xmlns:uxap='sap.uxap'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    busyIndicatorDelay='0'
	controllerName='planner.controller.arma.sqf.detail.SQFDetail'>

    <uxap:ObjectPageLayout
        upperCaseAnchorBar='false'
        showFooter='true'>

        <!-- HEADER -->
        <uxap:headerTitle>
            <core:Fragment fragmentName='planner.view.arma.sqf.detail.component.Header' type='XML' />
        </uxap:headerTitle>

        <!-- HEADER CONTENT -->
        <uxap:headerContent>
            <core:Fragment fragmentName='planner.view.arma.sqf.detail.component.HeaderContent' type='XML' />
        </uxap:headerContent>

        <uxap:sections>
            <core:Fragment fragmentName='planner.view.arma.sqf.detail.component.Syntax' type='XML' />
            <core:Fragment fragmentName='planner.view.arma.sqf.detail.component.Parameters' type='XML' />
            <core:Fragment fragmentName='planner.view.arma.sqf.detail.component.Examples' type='XML' />
        </uxap:sections>

        <uxap:footer>
        </uxap:footer>

    </uxap:ObjectPageLayout>

</mvc:View>