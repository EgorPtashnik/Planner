<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:core='sap.ui.core'>

    <VBox>
        <Label text='Описание' showColon='true' />

        <!-- DISPLAY MODE -->
        <FormattedText
            htmlText='{arma>info}'
            visible='{= !%{config>/editMode} }' />

        <Tokenizer tokens='{arma>tags}' visible='{= !%{config>/editMode} }'>
            <tokens>
                <Token text='{arma>tag/name}' />
            </tokens>
        </Tokenizer>

        <!-- EDIT MODE -->
        <TextArea
            width='100%'
            rows='5'
            value='{arma>info}'
            visible='{config>/editMode}' />
    </VBox>

</core:FragmentDefinition>