<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:core='sap.ui.core'>

    <uxap:ObjectPageSection>
        <uxap:subSections>
            <uxap:ObjectPageSubSection title='Параметры' titleUppercase='false'>
                <uxap:actions>
                    <Button
                        press='onPressAddParameter'
                        type='Ghost'
                        text='Добавить'
                        tooltip='Добавить'
                        visible='{config>/editMode}' />
                </uxap:actions>
                <uxap:blocks>
                    <Table
                        id='idSqcCommandParamsList'
                        autoPopinMode='true'
                        alternateRowColors='true'
                        items='{
                            path: "arma>params",
                            parameters: {
                                $expand: "type,command",
                                $orderby: "createdAt asc",
                                $$ownRequest: true
                            }
                        }'>
                        
                        <columns>
                            <Column width='8rem'>
                                <Text text='Параметр' />
                            </Column>
                            <Column width='5rem'>
                                <Text text='Тип' visible='{config>/editMode}' />
                            </Column>
                            <Column width='5rem'>
                                <Text text='По Умолчанию' />
                            </Column>
                            <Column width='auto' autoPopinWidth='{= %{config>/editMode} ? 999 : 30 }' popinDisplay='WithoutHeader'>
                                <Text text='Описание' />
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem vAlign='Top'>
                                <cells>
                                    <VBox>
                                        <!-- DISPLAY MODE -->
                                        <ObjectIdentifier title='{arma>name}' text='{arma>type/name}' visible='{= !%{config>/editMode} }' />
                                        <!-- EDIT MODE -->
                                        <Input value='{arma>name}' visible='{config>/editMode}' />
                                    </VBox>

                                    <!-- EDIT MODE -->
                                    <ComboBox
                                        selectedKey='{arma>type_code}'
                                        visible='{config>/editMode}'
                                        items='{path: "arma>/SqfType", templateShareable: "false"}'>
                                        <items>
                                            <core:Item key='{arma>code}' text='{arma>name}' />
                                        </items>
                                    </ComboBox>

                                    <VBox>
                                        <!-- DISPLAY MODE -->
                                        <Text text='{arma>defaultValue}' visible='{= !%{config>/editMode} }' />
                                        <!-- EDIT MODE -->
                                        <Input value='{arma>defaultValue}' visible='{config>/editMode}' />
                                    </VBox>

                                    <VBox>
                                        <!-- DISPLAY MODE -->
                                        <FormattedText htmlText='{arma>info}' visible='{= !%{config>/editMode} }' />
                                        <!-- EDIT MODE -->
                                        <TextArea cols='100' rows='5' value='{arma>info}' visible='{config>/editMode}' />
                                    </VBox>
                                </cells>
                            </ColumnListItem>
                        </items>

                    </Table>
                </uxap:blocks>
            </uxap:ObjectPageSubSection>
        </uxap:subSections>
    </uxap:ObjectPageSection>

</core:FragmentDefinition>