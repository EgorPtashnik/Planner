<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:core='sap.ui.core'>

    <uxap:ObjectPageSection title='Синтаксис' showTitle='false'>
        <uxap:heading>
            <OverflowToolbar design='Transparent' style='Clear'>
                <Title level='H3' text='Синтаксис' titleStyle='H4' />
                <Button press='onPressCopy(%{arma>syntax})' icon='sap-icon://copy' />
            </OverflowToolbar>
        </uxap:heading>
        <uxap:subSections>
            <uxap:ObjectPageSubSection>
                <uxap:blocks>
                    <VBox class='sapUiTinyMargin'>
                        <!-- DISPLAY MODE -->
                        <Text
                            text='{arma>syntax}'
                            visible='{= !%{config>/editMode} }' />
                        <!-- EDIT MODE -->
                        <TextArea
                            width='100%'
                            rows='5'
                            value='{arma>syntax}'
                            visible='{config>/editMode}' />
                    </VBox>
                </uxap:blocks>
            </uxap:ObjectPageSubSection>
        </uxap:subSections>
    </uxap:ObjectPageSection>

</core:FragmentDefinition>