<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:core='sap.ui.core'>

    <OverflowToolbar>
        <content>
            <Title text='Planner' />
            <IconTabHeader
                select='onSelectNavItem'
                visible='{= !%{device>/system/phone} }'
                selectedKey='{/selectedRoute}'
                items='{/routes}'>
                <items>
                    <IconTabFilter
                        text='{text}'
                        key='{key}' />
                </items>
            </IconTabHeader>

            <ToolbarSpacer />
        </content>
    </OverflowToolbar>

</core:FragmentDefinition>