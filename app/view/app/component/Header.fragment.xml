<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:core='sap.ui.core'>

    <f:DynamicPageTitle backgroundDesign='{= %{/darkMode} ? "Transparent" : "Solid" }'>

        <f:heading>
            <HBox alignItems='Center' justifyContent='Center' renderType='Bare'>
                <Button
                    press='onPressMobileNavMenu'
                    class='sapUiTinyMarginEnd'
                    type='Transparent'
                    icon='sap-icon://menu2'/>
                <Title text='PlanneR' />
            </HBox>
        </f:heading>

        <f:content>
            <Toolbar style='Clear'>
                <IconTabHeader
                    backgroundDesign='Transparent'
                    select='onSelectNavItem'
                    visible='{= !%{device>/system/phone} }'
                    selectedKey='{/selectedRoute}'
                    items='{/routes}'>
                    <items>
                        <IconTabFilter
                            text='{text}'
                            key='{key}' />
                    </items>
                </IconTabHeader>
            </Toolbar>
        </f:content>

        <f:actions>
            <Button
                press='onPressToggleDarkMode'
                icon='{= %{/darkMode} ? "sap-icon://light-mode" : "sap-icon://dark-mode" }'
                tooltip='{= %{/darkMode} ? "Светлая Тема" : "Тёмная Тема" }' />
            <Button
                ariaHasPopup='Menu'
                press='onOpenDatabaseMenu'
                icon='sap-icon://database'
                tooltip='База Данных' />
        </f:actions>

    </f:DynamicPageTitle>

</core:FragmentDefinition>