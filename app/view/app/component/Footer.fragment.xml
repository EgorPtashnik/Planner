<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:core='sap.ui.core'>

    <Bar>
        <contentMiddle>
            <ScrollContainer width='100%'>
                <HBox
                    justifyContent='SpaceAround'
                    alignItems='Center'
                    items='{/routes}'>
                    <items>
                        <Button
                            press='onPressFooterNavItem'
                            icon='{icon}'
                            type='{= %{/selectedRoute} === %{key} ? "Neutral" : "Transparent" }' />
                    </items>
                </HBox>
            </ScrollContainer>
        </contentMiddle>
    </Bar>

</core:FragmentDefinition>