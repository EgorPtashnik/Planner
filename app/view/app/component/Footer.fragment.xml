<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:core='sap.ui.core'>

    <Toolbar class='mobileFooter'>
        <ScrollContainer width='100%'>
            <HBox
                justifyContent='SpaceAround'
                alignItems='Center'
                items='{/routes}'>
                <items>
                    <Button
                        press='onPressFooterNavItem'
                        icon='{icon}'
                        type='{= %{/selectedRoute} === %{key} ? "Neutral" : "Transparent" }' />
                </items>
            </HBox>
        </ScrollContainer>
    </Toolbar>

</core:FragmentDefinition>