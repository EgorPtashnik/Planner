<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:core='sap.ui.core'>
    <Popover
        title='База Данных'
        placement='Bottom'>
        <content>
            <VBox>
                <Button
                    press='onPressDownloadDatabase'
                    width='100%'
                    type='Transparent'
                    icon='sap-icon://download'
                    text='Скачать'
                    class='actionItemButton' />
                <Button
                    press='onPressBackupDatabase'
                    width='100%'
                    type='Transparent'
                    icon='sap-icon://save'
                    text='Сохранить'
                    class='actionItemButton' />
                <Button
                    press='onPressRestoreDatabase'
                    width='100%'
                    type='Transparent'
                    icon='sap-icon://synchronize'
                    text='Восстановить'
                    class='actionItemButton' />
            </VBox>
        </content>
    </Popover>
</core:FragmentDefinition>