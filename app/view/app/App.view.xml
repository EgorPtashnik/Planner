<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    displayBlock='true'
    height='100%'
    busyIndicatorDelay='0'
	controllerName='planner.controller.app.App'>

    <f:DynamicPage
        class='sapUiNoContentPadding'
        showFooter='{device>/system/phone}'>

        <f:title>
            <f:DynamicPageTitle backgroundDesign='Transparent'>
                <f:heading>
                    <Title text='PlanneR' />
                </f:heading>

                <f:content>
                    <Toolbar style='Clear'>
                        <IconTabHeader
                            backgroundDesign='Transparent'
                            select='onSelectNavItem'
                            visible='{= !%{device>/system/phone} }'
                            selectedKey='{/selectedRoute}'
                            items='{/routes}'>
                            <items>
                                <IconTabFilter
                                    text='{text}'
                                    key='{key}' />
                            </items>
                        </IconTabHeader>
                    </Toolbar>
                </f:content>

                <f:actions>
                    <Button
                        press='onPressToggleDarkMode'
                        icon='{= %{/darkMode} ? "sap-icon://light-mode" : "sap-icon://dark-mode" }'
                        tooltip='{= %{/darkMode} ? "Светлая Тема" : "Тёмная Тема" }' />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <f:FlexibleColumnLayout
                id='app'
                stateChange='onFCLStateChange'
                layout='{/layout}' />
        </f:content>

        <f:footer>
            <Toolbar class='mobileFooter'>
                <ScrollContainer width='100%'>
                    <HBox
                        justifyContent='SpaceAround'
                        alignItems='Center'
                        items='{/routes}'>
                        <items>
                            <Button
                                press='onPressFooterNavItem'
                                icon='{icon}'
                                type='{= %{/selectedRoute} === %{key} ? "Neutral" : "Transparent" }' />
                        </items>
                    </HBox>
                </ScrollContainer>
            </Toolbar>
        </f:footer>
    </f:DynamicPage>
     
</mvc:View>