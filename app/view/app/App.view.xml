<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    displayBlock='true'
    height='100%'
	controllerName='planner.controller.app.App'>
        <Page showFooter='{device>/system/phone}'>

            <customHeader>
                <core:Fragment fragmentName='planner.view.app.component.Header' />
            </customHeader>

            <content>
                <f:FlexibleColumnLayout
                    id='app'
                    layout='{/layout}' />
            </content>

            <footer>
                <core:Fragment fragmentName='planner.view.app.component.Footer' />
            </footer>

        </Page>

</mvc:View>