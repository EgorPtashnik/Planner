<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    displayBlock='true'
    height='100%'
	controllerName='planner.controller.app.App'>
        <Page showFooter='{device>/system/phone}'>

            <customHeader>
                <OverflowToolbar>
                    <content>
                        <Title text='PlanneR' />
                        <IconTabHeader
                            select='onSelectNavItem'
                            visible='{= !%{device>/system/phone} }'
                            selectedKey='{/selectedRoute}'
                            items='{/routes}'>
                            <items>
                                <IconTabFilter
                                    text='{text}'
                                    key='{key}' />
                            </items>
                        </IconTabHeader>

                        <ToolbarSpacer />
                    </content>
                </OverflowToolbar>
            </customHeader>

            <content>
                <f:FlexibleColumnLayout
                    id='app'
                    stateChange='onFCLStateChange'
                    layout='{/layout}' />
            </content>

            <footer>
                <Bar>
                    <contentMiddle>
                        <ScrollContainer width='100%'>
                            <HBox
                                justifyContent='SpaceAround'
                                alignItems='Center'
                                items='{/routes}'>
                                <items>
                                    <Button
                                        press='onPressFooterNavItem'
                                        icon='{icon}'
                                        type='{= %{/selectedRoute} === %{key} ? "Neutral" : "Transparent" }' />
                                </items>
                            </HBox>
                        </ScrollContainer>
                    </contentMiddle>
                </Bar>
            </footer>

        </Page>

</mvc:View>