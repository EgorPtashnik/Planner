<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    displayBlock='true'
    height='100%'
    busyIndicatorDelay='0'
	controllerName='planner.controller.app.App'>

    <f:DynamicPage
        class='sapUiNoContentPadding'>

        <f:title>
            <core:Fragment fragmentName='planner.view.app.component.Header' />
        </f:title>

        <f:content>
            <f:FlexibleColumnLayout
                id='app'
                stateChange='onFCLStateChange'
                layout='{/layout}' />
        </f:content>

    </f:DynamicPage>
     
</mvc:View>