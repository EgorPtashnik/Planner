<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:core='sap.ui.core'>

    <OverflowToolbar>
        <ToolbarSpacer />

        <Button
            press='onPressAddTodoItem'
            type='Emphasized'
            icon='sap-icon://create-form'
            text='Новый Шаг'
            tooltip='Новый Шаг' />

        <Button
            press='onPressDeleteTodoParent'
            text='Удалить Этап'
            tooltip='Удалить Этап'
            icon='sap-icon://delete'
            type='Negative'>
            <layoutData>
                <OverflowToolbarLayoutData priority='AlwaysOverflow' />
            </layoutData>
        </Button>

    </OverflowToolbar>
    
</core:FragmentDefinition>