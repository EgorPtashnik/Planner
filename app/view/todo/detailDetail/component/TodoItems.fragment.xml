<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:core='sap.ui.core'>

    <uxap:ObjectPageSection
        title='Шаги ({todo>items/$count})'
        titleUppercase='false'
        showTitle='false'>
        <uxap:subSections>
            <uxap:ObjectPageSubSection>
                <uxap:blocks>
                    <Table
                        id='idTodoItemsList'
                        delete='onPressDeleteTodoItem'
                        showSeparators='Inner'
                        sticky='HeaderToolbar'
                        autoPopinMode='true'
                        fixedLayout='false'
                        mode='{= %{config>/editTodoItems} ? "Delete" : "None"}'
                        items='{
                            path: "todo>items",
                            parameters: {
                                $orderby: "sort desc, priority desc"
                            }
                        }'>

                        <noData>
                            <IllustratedMessage illustrationType='sapIllus-NoActivities' />
                        </noData>

                        <headerToolbar>
                            <OverflowToolbar design='Solid'>
                                <Title text='Шаги ({todo>items/$count})' />

                                <ToolbarSpacer />

                                <ToggleButton
                                    type='Ghost'
                                    icon='sap-icon://edit'
                                    tooltip='Редактировать'
                                    pressed='{config>/editTodoItems}'>
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                    </layoutData>
                                </ToggleButton>

                                <OverflowToolbarButton
                                    press='onPressAddTodoItem'
                                    icon='sap-icon://add-activity'
                                    text='Добавить Шаг'
                                    tooltip='Добавить Шаг' />

                                <OverflowToolbarButton
                                    press='onPressToggleVisibleItems'
                                    type='Transparent'
                                    icon='{= %{config>/showCompletedTodoItems} ? "sap-icon://hide" : "sap-icon://show" }'
                                    text='{= %{config>/showCompletedTodoItems} ? "Скрыть" : "Показать" } Законченные'
                                    tooltip='{= %{config>/showCompletedTodoItems} ? "Скрыть" : "Показать" } Законченные'>
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority='AlwaysOverflow' />
                                    </layoutData>
                                </OverflowToolbarButton>

                                <OverflowToolbarButton
                                    press='onPressDeleteCompletedItems'
                                    type='Transparent'
                                    icon='sap-icon://eraser'
                                    text='Удалить Законченные'
                                    tooltip='Удалить Законченные'>
                                    <layoutData>
                                        <OverflowToolbarLayoutData priority='AlwaysOverflow' />
                                    </layoutData>
                                </OverflowToolbarButton>
                            </OverflowToolbar>
                        </headerToolbar>

                        <columns>
                            <Column width='auto' importance='High' >
                                <Text text='Шаг'/>
                            </Column>
                            <Column hAlign='Right' importance='Medium' popinDisplay='{= %{config>/editTodoItems} ? "Block" : "WithoutHeader" }'>
                                <Text text='Приоритет' />
                            </Column>
                            <Column importance='Low' autoPopinWidth='999' popinDisplay='{= %{config>/editTodoItems} ? "Block" : "Inline" }'>
                                <Text text='Заметка' />
                            </Column>
                            <Column hAlign='Right' importance='High' visible='{= !%{config>/editTodoItems} }' />
                        </columns>

                        <ColumnListItem
                            vAlign='Top'
                            visible="{=
                                %{config>/showCompletedTodoItems} ||
                                %{todo>status} === 0 || %{todo>status} === 1
                            }">
                            <cells>
                                <VBox>
                                    <!-- DISPLAY -->
                                    <ObjectIdentifier
                                        title='{todo>name}'
                                        visible='{= !%{config>/editTodoItems} }'/>
                                    <ObjectStatus
                                        text='{path: "todo>status", formatter: ".Formatter.getProgressStatusText"}' 
                                        state='{path: "todo>status", formatter: ".Formatter.getProgressStatusState"}'
                                        visible='{= !%{config>/editTodoItems} }' />
                                    <!-- EDIT -->
                                    <Input
                                        width='100%'
                                        value='{todo>name}'
                                        visible='{config>/editTodoItems}' />
                                </VBox>

                                <VBox>
                                    <!-- DISPLAY -->
                                    <GenericTag
                                        design='StatusIconHidden'
                                        text='{ path: "todo>priority", formatter: ".Formatter.getPriorityText" }'
                                        status='{ path: "todo>priority", formatter: ".Formatter.getPriorityState" }'
                                        visible='{= !%{config>/editTodoItems} }' />
                                    <!-- EDIT -->
                                    <Select
                                        width='100%'
                                        selectedKey='{todo>priority}'
                                        visible='{config>/editTodoItems}'
                                        items='{path: "common>/PriorityCode", templateShareable: false}'>
                                        <items>
                                            <core:Item key='{common>code}' text='{common>name}' />
                                        </items>
                                    </Select>
                                </VBox>

                                <VBox>
                                    <!-- DISPLAY -->
                                    <Text
                                        emptyIndicatorMode='{= !!%{todo>info} ? "Off" : "On" }'
                                        text='{todo>info}'
                                        visible='{= !%{config>/editTodoItems} }' />
                                    <!-- EDIT -->
                                    <Input
                                        width='100%'
                                        value='{todo>info}'
                                        visible='{config>/editTodoItems}' />
                                </VBox>

                                <OverflowToolbar style='Clear'>
                                    <ToolbarSpacer />
                                    <Button
                                        press='onPressChangeTodoItemStatus($event, 1)'
                                        type='Accept'
                                        icon='sap-icon://process'
                                        tooltip='Начать'
                                        visible='{= %{todo>status} === 0 &amp;&amp; !%{config>/editTodoItems} }'>
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority='NeverOverflow' />
                                        </layoutData>
                                    </Button>
                                    <Button
                                        press='onPressChangeTodoItemStatus($event, 2)'
                                        type='Accept'
                                        icon='sap-icon://accept'
                                        tooltip='Завершить'
                                        visible='{= %{todo>status} === 1 &amp;&amp; !%{config>/editTodoItems} }'>
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority='NeverOverflow' />
                                        </layoutData>
                                    </Button>
                                    <Button
                                        press='onPressChangeTodoItemStatus($event, 3)'
                                        type='Reject'
                                        icon='sap-icon://decline'
                                        tooltip='Отменить'
                                        visible='{= %{todo>status} === 1 &amp;&amp; !%{config>/editTodoItems} }'>
                                        <layoutData>
                                            <OverflowToolbarLayoutData priority='NeverOverflow' />
                                        </layoutData>
                                    </Button>
                                </OverflowToolbar>
                            </cells>
                        </ColumnListItem>

                    </Table>
                </uxap:blocks>
            </uxap:ObjectPageSubSection>
        </uxap:subSections>
    </uxap:ObjectPageSection>

</core:FragmentDefinition>