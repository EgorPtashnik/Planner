<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:core='sap.ui.core'>
    
    <uxap:ObjectPageSection
        title='Заметки'
        titleUppercase='false'
        showTitle='false'
        visible='{= !%{config>/fullScreenTodoItems} }'>
        <uxap:subSections>
            <uxap:ObjectPageSubSection>
                <uxap:blocks>
                    <Panel headerText='Заметки'>
                        <Text text='{todo>info}' emptyIndicatorMode='{= !!%{todo>info} ? "Off" : "On" }'/>
                    </Panel>
                </uxap:blocks>
            </uxap:ObjectPageSubSection>
        </uxap:subSections>
    </uxap:ObjectPageSection>

</core:FragmentDefinition>