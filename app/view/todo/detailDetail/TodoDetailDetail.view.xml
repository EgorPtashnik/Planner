<mvc:View
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:form='sap.ui.layout.form'
    xmlns:core='sap.ui.core'
    xmlns:mvc='sap.ui.core.mvc'
	controllerName='planner.controller.todo.detailDetail.TodoDetailDetail'>

    <uxap:ObjectPageLayout
        preserveHeaderStateOnScroll='true'
        upperCaseAnchorBar='false'>

        <!-- HEADER -->
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>

                <uxap:breadcrumbs>
                    <Breadcrumbs currentLocationText='{todo>name}'>
                        <links>
                            <Link press='onPressCloseAllPages' text='Списки Дел' />
                            <Link press='onPressClosePage' text='{todo>list/name}' />
                        </links>
                    </Breadcrumbs>
                </uxap:breadcrumbs>

                <uxap:navigationActions>
                    <Button
                        press='onPressClosePage'
                        icon='sap-icon://decline' />
                </uxap:navigationActions>

                <uxap:actions>
                    <Button
                        press='onPressDelete'
                        text='Удалить'
                        icon='sap-icon://delete'
                        type='Reject'>
                        <layoutData>
                            <OverflowToolbarLayoutData priority='AlwaysOverflow' />
                        </layoutData>
                    </Button>
                </uxap:actions>

                <uxap:expandedHeading>
                    <Title text='{todo>name}' wrapping='true' />
                </uxap:expandedHeading>

                <uxap:expandedContent>
                    <VBox>
                        <ObjectStatus title='Обновлено' text='{todo>modifiedAt}' />
                        <GenericTag
                            design='StatusIconHidden'
                            text='{ path: "todo>priority", formatter: ".Formatter.getPriorityText" }'
                            status='{ path: "todo>priority", formatter: ".Formatter.getPriorityState" }' />
                    </VBox>
                </uxap:expandedContent>

                <uxap:snappedHeading>
                    <Title text='{todo>name}' />
                </uxap:snappedHeading>

                <uxap:snappedContent>
                    <VBox>
                        <ObjectStatus title='Обновлено' text='{todo>modifiedAt}' />
                        <GenericTag
                            design='StatusIconHidden'
                            text='{ path: "todo>priority", formatter: ".Formatter.getPriorityText" }'
                            status='{ path: "todo>priority", formatter: ".Formatter.getPriorityState" }' />
                    </VBox>
                </uxap:snappedContent>

            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <!-- HEADER CONTENT -->
        <uxap:headerContent>
            <form:SimpleForm
                editable='true'
                layout='ColumnLayout'
                columnsL='1'
                labelSpanL='12'
                columnsM='1'
                labelSpanM='12'>
                <form:content>
                    <core:Title text='Общее' />
                    <Label text='Название' />
                    <Input id='idTodoParentNameInput' value='{todo>name}' />

                    <Label text='Приоритет' />
                    <Select
                        forceSelection='false'
                        selectedKey='{todo>priority}'
                        items='{common>/PriorityCode}'>
                        <items>
                            <core:Item key='{common>code}' text='{common>name}' />
                        </items>
                    </Select>

                    <Label text='Заметки' />
                    <TextArea rows='5' value='{todo>info}' />

                </form:content>
            </form:SimpleForm>
        </uxap:headerContent>

        <!-- SECTIONS -->
        <uxap:sections>
            <!-- INFORMATION -->
            <uxap:ObjectPageSection title='Заметки' titleUppercase='false' showTitle='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <Panel headerText='Заметки'>
                                <Text text='{todo>info}' emptyIndicatorMode='{= !!%{todo>info} ? "Off" : "On" }'/>
                            </Panel>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            
            <!-- ACTIVITIES -->
            <uxap:ObjectPageSection title='Шаги ({todo>items/$count})' titleUppercase='false' showTitle='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <Table
                                id='idTodoItemList'
                                delete='onPressDeleteTodoItem'
                                showSeparators='Inner'
                                sticky='HeaderToolbar'
                                autoPopinMode='true'
                                mode='{= %{config>/editTodoItems} ? "Delete" : "None"}'
                                items='{todo>items}'>

                                <noData>
                                    <IllustratedMessage illustrationType='sapIllus-NoActivities' />
                                </noData>

                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text='Шаги ({todo>items/$count})' />
                                        <ToolbarSpacer />
                                        <ToggleButton
                                            icon='sap-icon://edit'
                                            tooltip='Редактировать'
                                            pressed='{config>/editTodoItems}'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                                            </layoutData>
                                        </ToggleButton>
                                        <OverflowToolbarButton
                                            press='onPressAddTodoItem'
                                            icon='sap-icon://add-activity'
                                            text='Добавить Шаг'
                                            tooltip='Добавить Шаг' />
                                    </OverflowToolbar>
                                </headerToolbar>

                                <columns>
                                    <Column importance='High' >
                                        <Text text='Шаг'/>
                                    </Column>
                                    <Column hAlign='Right' importance='Low' popinDisplay='WithoutHeader'>
                                        <Text text='Приоритет' />
                                    </Column>
                                    <Column width='8rem' hAlign='Right' importance='High' />
                                </columns>

                                <ColumnListItem vAlign='Top'>
                                    <cells>
                                        <VBox>
                                            <!-- DISPLAY -->
                                            <ObjectIdentifier
                                                title='{todo>name}'
                                                visible='{= !%{config>/editTodoItems} }'/>
                                            <ObjectStatus
                                                text='{path: "todo>status", formatter: ".Formatter.getProgressStatusText"}' 
                                                state='{path: "todo>status", formatter: ".Formatter.getProgressStatusState"}'
                                                visible='{= !%{config>/editTodoItems} }' />
                                            <!-- EDIT -->
                                            <Input
                                                value='{todo>name}'
                                                visible='{config>/editTodoItems}' />
                                        </VBox>

                                        <VBox>
                                            <!-- DISPLAY -->
                                            <GenericTag
                                                design='StatusIconHidden'
                                                text='{ path: "todo>priority", formatter: ".Formatter.getPriorityText" }'
                                                status='{ path: "todo>priority", formatter: ".Formatter.getPriorityState" }'
                                                visible='{= !%{config>/editTodoItems} }' />
                                            <!-- EDIT -->
                                            <Select
                                                selectedKey='{todo>priority}'
                                                visible='{config>/editTodoItems}'
                                                items='{path: "common>/PriorityCode", templateShareable: false}'>
                                                <items>
                                                    <core:Item key='{common>code}' text='{common>name}' />
                                                </items>
                                            </Select>
                                        </VBox>

                                        <OverflowToolbar style='Clear'>
                                            <ToolbarSpacer />
                                            <Button
                                                press='onPressChangeTodoItemStatus($event, 1)'
                                                type='Accept'
                                                icon='sap-icon://process'
                                                tooltip='Начать'
                                                visible='{= %{todo>status} === 0 &amp;&amp; !%{config>/editTodoItems} }'>
                                                <layoutData>
                                                    <OverflowToolbarLayoutData priority='NeverOverflow' />
                                                </layoutData>
                                            </Button>
                                            <Button
                                                press='onPressChangeTodoItemStatus($event, 2)'
                                                type='Accept'
                                                icon='sap-icon://accept'
                                                tooltip='Завершить'
                                                visible='{= %{todo>status} === 1 &amp;&amp; !%{config>/editTodoItems} }'>
                                                <layoutData>
                                                    <OverflowToolbarLayoutData priority='NeverOverflow' />
                                                </layoutData>
                                            </Button>
                                            <Button
                                                press='onPressChangeTodoItemStatus($event, 3)'
                                                type='Reject'
                                                icon='sap-icon://decline'
                                                tooltip='Отменить'
                                                visible='{= %{todo>status} === 1 &amp;&amp; !%{config>/editTodoItems} }'>
                                                <layoutData>
                                                    <OverflowToolbarLayoutData priority='NeverOverflow' />
                                                </layoutData>
                                            </Button>
                                        </OverflowToolbar>
                                    </cells>
                                </ColumnListItem>

                            </Table>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>

    </uxap:ObjectPageLayout>

</mvc:View>