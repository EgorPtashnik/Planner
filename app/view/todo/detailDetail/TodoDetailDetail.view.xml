<mvc:View
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:form='sap.ui.layout.form'
    xmlns:core='sap.ui.core'
    xmlns:mvc='sap.ui.core.mvc'
	controllerName='planner.controller.todo.detailDetail.TodoDetailDetail'>

    <uxap:ObjectPageLayout
        upperCaseAnchorBar='false'
        useIconTabBar='true'>

        <!-- HEADER -->
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>

                <uxap:navigationActions>
                    <Button
                        press='.header.onPressClosePage'
                        icon='sap-icon://decline' />
                </uxap:navigationActions>

                <uxap:expandedHeading>
                    <Title text='{todoService>name}' />
                </uxap:expandedHeading>

                <uxap:expandedContent>
                    <ObjectStatus title='Обновлено' text='{todoService>modifiedAt}' />
                </uxap:expandedContent>

                <uxap:snappedHeading>
                    <Title text='{todoService>name}' />
                </uxap:snappedHeading>

                <uxap:snappedContent>
                    <ObjectStatus title='Обновлено' text='{todoService>modifiedAt}' />
                </uxap:snappedContent>

            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <!-- HEADER CONTENT -->
        <uxap:headerContent>
            <form:SimpleForm
                editable='true'
                layout='ColumnLayout'
                columnsL='1'
                labelSpanL='12'
                columnsM='1'
                labelSpanM='12'>
                <form:content>
                    <core:Title text='Общее' />
                    <Label text='Название' />
                    <Input id='idTodoParentNameInput' value='{todoService>name}' />

                    <Label text='Описание' />
                    <TextArea rows='5' value='{todoService>info}' />

                </form:content>
            </form:SimpleForm>
        </uxap:headerContent>

        <!-- SECTIONS -->
        <uxap:sections>

            <!-- INFORMATION -->
            <uxap:ObjectPageSection title='Информация' titleUppercase='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <Text text='{todoService>info}' emptyIndicatorMode='{= !!%{todoService>info} ? "Off" : "On" }'/>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            
            <!-- ACTIVITIES -->
            <uxap:ObjectPageSection title='Шаги({todoService>items/$count})' titleUppercase='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <Table
                                items='{todoService>items}'>

                                <noData>
                                    <IllustratedMessage />
                                </noData>

                                <headerToolbar>
                                    <OverflowToolbar>
                                    </OverflowToolbar>
                                </headerToolbar>

                                <columns>
                                    <Column>
                                        <Text text='Шаг' />
                                    </Column>
                                </columns>

                                <ColumnListItem>
                                    <cells>
                                        <ObjectIdentifier title='{todoService>name}' />
                                    </cells>
                                </ColumnListItem>

                            </Table>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>

    </uxap:ObjectPageLayout>

</mvc:View>