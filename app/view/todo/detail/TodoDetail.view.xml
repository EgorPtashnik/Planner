<mvc:View
    xmlns:uxap='sap.uxap'
    xmlns:core='sap.ui.core'
    xmlns:mvc='sap.ui.core.mvc'
    busyIndicatorDelay='0'
	controllerName='planner.controller.todo.detail.TodoDetail'>

    <uxap:ObjectPageLayout
        preserveHeaderStateOnScroll='true'
        upperCaseAnchorBar='false'
        showAnchorBar='{= !%{config>/compactView} }'
        showHeaderContent='{= !%{config>/compactView} }'
        showFooter='{device>/system/phone}'>

        <!-- HEADER -->
        <uxap:headerTitle>
            <core:Fragment fragmentName='planner.view.todo.detail.component.Header' type='XML' />
        </uxap:headerTitle>

        <!-- HEADER CONTENT -->
        <uxap:headerContent>
            <core:Fragment fragmentName='planner.view.todo.detail.component.HeaderContent' type='XML' />
        </uxap:headerContent>

        <!-- SECTIONS -->
        <uxap:sections>
            <!-- INFORMATION -->
            <core:Fragment fragmentName='planner.view.todo.detail.component.Notes' type='XML' />
            
            <!-- ACTIVITIES -->
            <core:Fragment fragmentName='planner.view.todo.detail.component.TodoParents' type='XML' />
        </uxap:sections>

    </uxap:ObjectPageLayout>

</mvc:View>