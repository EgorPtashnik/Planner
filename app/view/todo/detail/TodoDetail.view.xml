<mvc:View
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:form='sap.ui.layout.form'
    xmlns:core='sap.ui.core'
    xmlns:mvc='sap.ui.core.mvc'
	controllerName='planner.controller.todo.detail.TodoDetail'>

    <uxap:ObjectPageLayout
        upperCaseAnchorBar='false'
        useIconTabBar='true'>

        <!-- HEADER -->
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>

                <uxap:breadcrumbs>
                    <Breadcrumbs currentLocationText='{todoService>name}'>
                        <links>
                            <Link press='onPressClosePage' text='Списки Дел' />
                        </links>
                    </Breadcrumbs>
                </uxap:breadcrumbs>

                <uxap:navigationActions>
                    <Button
                        press='onPressClosePage'
                        icon='sap-icon://decline'
                        visible='{= !%{/layout}.includes("One") &amp;&amp; !%{/layout}.includes("Three") }' />
                </uxap:navigationActions>

                <uxap:actions>
                    <Button
                        press='onPressDelete'
                        text='Удалить'
                        icon='sap-icon://delete'
                        type='Reject'>
                        <layoutData>
                            <OverflowToolbarLayoutData priority='AlwaysOverflow' />
                        </layoutData>
                    </Button>
                </uxap:actions>

                <uxap:expandedHeading>
                    <Title text='{todoService>name}' />
                </uxap:expandedHeading>

                <uxap:expandedContent>
                    <ObjectStatus title='Обновлено' text='{todoService>modifiedAt}' />
                </uxap:expandedContent>

                <uxap:snappedHeading>
                    <Title text='{todoService>name}' />
                </uxap:snappedHeading>

                <uxap:snappedContent>
                    <ObjectStatus title='Обновлено' text='{todoService>modifiedAt}' />
                </uxap:snappedContent>

            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <!-- HEADER CONTENT -->
        <uxap:headerContent>
            <form:SimpleForm
                editable='true'
                layout='ColumnLayout'
                columnsL='1'
                labelSpanL='12'
                columnsM='1'
                labelSpanM='12'>
                <form:content>
                    <core:Title text='Общее' />
                    <Label text='Название' />
                    <Input id='idTodoListNameInput' value='{todoService>name}' />

                    <Label text='Описание' />
                    <TextArea rows='5' value='{todoService>info}' />

                </form:content>
            </form:SimpleForm>
        </uxap:headerContent>

        <!-- SECTIONS -->
        <uxap:sections>

            <!-- INFORMATION -->
            <uxap:ObjectPageSection title='Информация' titleUppercase='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <Text class='sapUiTinyMargin' text='{todoService>info}' emptyIndicatorMode='{= !!%{todoService>info} ? "Off" : "On" }'/>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
            
            <!-- ACTIVITIES -->
            <uxap:ObjectPageSection title='Этапы ({todoService>items/$count})' titleUppercase='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <Table
                                id='idTodoParentList'
                                items='{todoService>items}'>

                                <noData>
                                    <IllustratedMessage />
                                </noData>

                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text='Этапы ({todoService>items/$count})' />
                                        <ToolbarSpacer />

                                        <Button
                                            press='onPressAddTodoParent'
                                            text='Добавить Этап'
                                            tooltip='Добавить Этап' />
                                    </OverflowToolbar>
                                </headerToolbar>

                                <columns>
                                    <Column>
                                        <Text text='Этап' />
                                    </Column>
                                </columns>

                                <ColumnListItem
                                    press='onPressTodoParentItem'
                                    navigated='{= %{/detailDetailID} === %{todoService>ID} }'
                                    type='{= %{/detailDetailID} === %{todoService>ID} ? "Active" : "Navigation" }'>
                                    <cells>
                                        <ObjectIdentifier title='{todoService>name}' />
                                    </cells>
                                </ColumnListItem>

                            </Table>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>

    </uxap:ObjectPageLayout>

</mvc:View>