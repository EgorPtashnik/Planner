<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:core='sap.ui.core'>
    
    <uxap:ObjectPageDynamicHeaderTitle>

        <uxap:breadcrumbs>
            <Breadcrumbs currentLocationText='{todo>name}'>
                <links>
                    <Link press='onPressClosePage' text='Списки Дел' />
                </links>
            </Breadcrumbs>
        </uxap:breadcrumbs>

        <uxap:navigationActions>
            <Button
                press='onPressToggleCompactView'
                icon='{= !%{config>/compactView} ? "sap-icon://decrease-line-height" : "sap-icon://increase-line-height" }'
                tooltip='{= %{config>/compactView} ? "Показать Меньше" : "Показать Больше"}' />
            <Button
                press='onPressClosePage'
                icon='sap-icon://decline'
                visible='{= !%{/layout}.includes("One") &amp;&amp; !%{/layout}.includes("Three") }' />
        </uxap:navigationActions>

        <uxap:actions>
            <Button
                press='onPressDeleteTodoList'
                text='Удалить Спиосок'
                tooltip='Удалить Спиосок'
                icon='sap-icon://delete'
                type='Negative'>
                <layoutData>
                    <OverflowToolbarLayoutData priority='AlwaysOverflow' />
                </layoutData>
            </Button>
        </uxap:actions>

        <uxap:expandedHeading>
            <Title text='{todo>name}' wrapping='{= !%{config>/compactView} }' />
        </uxap:expandedHeading>

        <uxap:expandedContent>
            <ObjectStatus title='Обновлено' text='{todo>modifiedAt}' visible='{= !%{config>/compactView} }' />
        </uxap:expandedContent>

        <uxap:snappedHeading>
            <Title text='{todo>name}' />
        </uxap:snappedHeading>

        <uxap:snappedContent>
            <ObjectStatus title='Обновлено' text='{todo>modifiedAt}'  visible='{= !%{config>/compactView} }' />
        </uxap:snappedContent>

    </uxap:ObjectPageDynamicHeaderTitle>

</core:FragmentDefinition>