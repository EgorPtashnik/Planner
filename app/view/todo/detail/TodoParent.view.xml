<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:core='sap.ui.core'
    xmlns:mvc='sap.ui.core.mvc'
	controllerName='planner.controller.todo.detail.TodoParent'>

    <f:DynamicPage showFooter='true'>

        <f:title>
            <f:DynamicPageTitle>

                <f:navigationActions>
                    <Button
                        press='onPressClosePage'
                        icon='sap-icon://decline'
                        visible='{= %{/layout} !== "OneColumn" }' />
                </f:navigationActions>

                <f:heading>
                    <Title text='New List' />
                </f:heading>

            </f:DynamicPageTitle>
        </f:title>

    </f:DynamicPage>

</mvc:View>