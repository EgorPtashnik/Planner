<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:core='sap.ui.core'>

    <Table
        id='idTodoListsList'
        items='{
            path: "todo>/TodoList",
            parameters: { $count: true }
        }'>

        <noData>
            <IllustratedMessage />
        </noData>

        <headerToolbar>
            <OverflowToolbar design='Solid'>
                <Title
                    text='Списки ({config>/todoListCount})'
                    visible='{= !%{config>/showTodoListsSearch} }' />

                <VBox
                    width='100%'
                    visible='{config>/showTodoListsSearch}'>
                    <SearchField
                        change='onChangeTodoListsSearch'
                        showSearchButton='false'>
                        <layoutData>
                            <OverflowToolbarLayoutData priority='NeverOverflow' />
                        </layoutData>
                    </SearchField>
                </VBox>

                <ToolbarSpacer />

                <ToggleButton
                    icon='sap-icon://search'
                    tooltip='Поиск'
                    pressed='{config>/showTodoListsSearch}'>
                    <layoutData>
                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                    </layoutData>
                </ToggleButton>

                <OverflowToolbarButton
                    press='onPressCreateTodoList'
                    type='Emphasized'
                    icon='sap-icon://create-form'
                    text='Создать Список'
                    tooltip='Создать Список'
                    visible='{= !%{device>/system/phone} }' />

            </OverflowToolbar>
        </headerToolbar>

        <columns>
            <Column>
                <Text text='Список' />
            </Column>
        </columns>

        <items>
            <ColumnListItem
                press='onPressListItem'
                navigated='{= %{/detailID} === %{todo>ID} }'
                highlight='{= %{/detailID} === %{todo>ID} ? "Information" : "None" }'
                type='{= %{/detailID} === %{todo>ID} ? "Active" : "Navigation" }'>
                <cells>
                    <ObjectIdentifier title='{todo>name}' />
                </cells>
            </ColumnListItem>
        </items>

    </Table>

</core:FragmentDefinition>