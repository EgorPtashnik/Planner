<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:core='sap.ui.core'>

    <f:DynamicPageTitle>

        <f:heading>
            <Title text='Дела' />
        </f:heading>

        <f:actions>
            <Button
                press='onPressCreateTodoList'
                type='Emphasized'
                text='Создать Список'
                tooltip='Создать Список'>
                <layoutData>
                    <OverflowToolbarLayoutData priority='NeverOverflow' />
                </layoutData>
            </Button>
        </f:actions>

    </f:DynamicPageTitle>

</core:FragmentDefinition>
