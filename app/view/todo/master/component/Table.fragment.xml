<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:core='sap.ui.core'>

    <Table
        id='idTodoList'
        items='{todoService>/TodoList}'>

        <noData>
            <IllustratedMessage />
        </noData>

        <columns>
            <Column>
                <Text text='Name' />
            </Column>
        </columns>

        <items>
            <ColumnListItem>
                <cells>
                    <ObjectIdentifier
                        title='{todoService>name}' />
                </cells>
            </ColumnListItem>
        </items>

    </Table>

</core:FragmentDefinition>