<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:fb='sap.ui.comp.filterbar'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    busyIndicatorDelay='0'
	controllerName='planner.controller.todo.master.TodoMaster'>

    <f:DynamicPage headerExpanded='false'>



        <!-- Title -->
        <f:title>
            <f:DynamicPageTitle>

                <f:heading>
                    <Title text='Мои Дела' />
                </f:heading>

            </f:DynamicPageTitle>
        </f:title>



        <!-- FILTER BAR -->
        <f:header>
            <f:DynamicPageHeader>
                <fb:FilterBar showGoOnFB="false" useToolbar="false">
                    <fb:filterGroupItems>

                        <fb:FilterGroupItem name="fbSearch" label="Поиск" groupName="basic" visibleInFilterBar="true">
                            <fb:control>
                                <SearchField change='onChangeTodoListSearch' />
                            </fb:control>
                        </fb:FilterGroupItem>

                    </fb:filterGroupItems>
                </fb:FilterBar>
            </f:DynamicPageHeader>
        </f:header>


        <!-- TABLE <TodoList> -->
        <f:content>
            <Table
                id='idTodoList'
                sticky='HeaderToolbar'
                autoPopinMode='true'
                items='{
                    path: "todo>/List",
                    parameters: {
                        $count: true,
                        $expand: "items,doneItems,tag"
                    }
                }'>

                <noData>
                    <IllustratedMessage
                        title='Нет данных'
                        description='Создайте новое дело чтобы увидеть данные.'
                        illustrationType='sapIllus-NoActivities' />
                </noData>

                <headerToolbar>
                    <OverflowToolbar>
                        <Title text='Дела ({config>/listCount})' />

                        <ToolbarSpacer />
                        
                        <Button
                            press='onPressCreateList'
                            type='Ghost'
                            text='Создать'
                            tooltip='Создать'>
                            <layoutData>
                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                            </layoutData>
                        </Button>

                        <OverflowToolbarButton
                            press='onPressManageTags'
                            icon='sap-icon://tag'
                            tooltip='Управление тегами'
                            text='Теги'>
                            <layoutData>
                                <OverflowToolbarLayoutData group='1' />
                            </layoutData>
                        </OverflowToolbarButton>

                        <OverflowToolbarButton
                            press='onPressSort'
                            type='Transparent'
                            icon='sap-icon://sort'
                            text='Сортировка'
                            tooltip='Сортировка'>
                            <layoutData>
                                <OverflowToolbarLayoutData group='1' />
                            </layoutData>
                        </OverflowToolbarButton>
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column
                        width='auto'
                        importance='High'>
                        <Text text='Имя' />
                    </Column>

                    <Column
                        width='5rem'
                        importance='Low'
                        popinDisplay='WithoutHeader'>
                        <Text text='Тег' />
                    </Column>

                    <Column
                        width='8rem'
                        importance='Low'
                        popinDisplay='Inline'>
                        <Text text='Статус' />
                    </Column>

                    <Column
                        width='8rem'
                        hAlign='Right'
                        importance='High'>
                        <Text text='Приоритет' />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem
                        press='onPressListItem'
                        vAlign='Top'
                        navigated='{= %{/detailID} === %{todo>ID} }'
                        highlight='{= %{/detailID} === %{todo>ID} ? "Information" : "None" }'
                        type='{= %{/detailID} === %{todo>ID} ? "Active" : "Navigation" }'>
                        <cells>
                            <ObjectIdentifier
                                title='{todo>name}'
                                text='{todo>doneItems/$count} из {todo>items/$count}' />

                            <GenericTag
                                design='StatusIconHidden'
                                status='{= %{todo>tag/color} || "None"}'
                                text='{= %{todo>tag/name} || "Нет" }' />

                            <ObjectStatus
                                inverted='true'
                                class='sapMObjectStatusLongText'
                                text='{=
                                    %{todo>status} === 1 ? "Выполняется" :
                                    %{todo>items/$count} === %{todo>doneItems/$count} &amp;&amp; %{todo>doneItems/$count} !== 0 ? "Выполнен" :
                                    "Не выполняется"
                                }'
                                state='{=
                                    %{todo>status} === 1 ? "Warning" :
                                    %{todo>items/$count} === %{todo>doneItems/$count} &amp;&amp; %{todo>doneItems/$count} !== 0 ? "Success" :
                                    "Information"
                                }' />

                            <ObjectStatus
                                text='{ path: "todo>priority", formatter: ".Formatter.getPriorityText" }'
                                state='{ path: "todo>priority", formatter: ".Formatter.getPriorityState" }' />
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>
        </f:content>

    </f:DynamicPage>

</mvc:View>