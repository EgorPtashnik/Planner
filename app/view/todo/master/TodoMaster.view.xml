<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
	controllerName='planner.controller.todo.master.TodoMaster'>

    <f:DynamicPage showFooter='true'>

        <!-- HEADER -->
        <f:title>
            <f:DynamicPageTitle>

                <f:heading>
                    <Title text='Списки Дел' />
                </f:heading>

            </f:DynamicPageTitle>
        </f:title>

        <!-- CONTENT -->
        <f:content>
            <Table
                id='idTodoList'
                items='{todo>/TodoList}'>

                <noData>
                    <IllustratedMessage />
                </noData>

                <columns>
                    <Column>
                        <Text text='Список' />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem
                        press='onPressListItem'
                        navigated='{= %{/detailID} === %{todo>ID} }'
                        type='{= %{/detailID} === %{todo>ID} ? "Active" : "Navigation" }'>
                        <cells>
                            <ObjectIdentifier title='{todo>name}' />
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>
        </f:content>

        <!-- FOOTER -->
        <f:footer>
            <OverflowToolbar>
                <content>
                    <ToolbarSpacer />
                    
                    <Button
                        press='onPressCreate'
                        text='Создать Список'
                        tooltip='Создать Список'
                        type='Emphasized' />
                </content>
            </OverflowToolbar>
        </f:footer>

    </f:DynamicPage>

</mvc:View>