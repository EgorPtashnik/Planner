<mvc:View
    xmlns='sap.m'
    xmlns:f='sap.f'
    xmlns:fb='sap.ui.comp.filterbar'
    xmlns:mvc='sap.ui.core.mvc'
    xmlns:core='sap.ui.core'
    busyIndicatorDelay='0'
	controllerName='planner.controller.todo.master.TodoMaster'>

    <f:DynamicPage headerExpanded='false'>



        <!-- Title -->
        <f:title>
            <f:DynamicPageTitle>

                <f:heading>
                    <Title text='Дела ({config>/listCount})' />
                </f:heading>

            </f:DynamicPageTitle>
        </f:title>



        <!-- FILTER BAR -->
        <f:header>
            <f:DynamicPageHeader>
                <fb:FilterBar showGoOnFB="false" useToolbar="false">
                    <fb:filterGroupItems>

                        <fb:FilterGroupItem name="fbSearch" label="Поиск" groupName="basic" visibleInFilterBar="true">
                            <fb:control>
                                <SearchField change='onChangeTodoListSearch' />
                            </fb:control>
                        </fb:FilterGroupItem>

                    </fb:filterGroupItems>
                </fb:FilterBar>
            </f:DynamicPageHeader>
        </f:header>


        <!-- TABLE <TodoList> -->
        <f:content>
            <Table
                id='idTodoList'
                inset='true'
                sticky='HeaderToolbar'
                items='{ path: "todo>/List", parameters: { $count: true } }'>

                <noData>
                    <IllustratedMessage
                        title='Нет данных'
                        description='Создайте новое дело чтобы увидеть данные.'
                        illustrationType='sapIllus-NoActivities' />
                </noData>

                <headerToolbar>
                    <OverflowToolbar design='Solid'>

                        <ToolbarSpacer />

                        <Button
                            press='onPressCreateList'
                            text='Создать'
                            tooltip='Создать'>
                            <layoutData>
                                <OverflowToolbarLayoutData priority='NeverOverflow' />
                            </layoutData>
                        </Button>
                        <OverflowToolbarButton
                            press='onPressManageTags'
                            icon='sap-icon://tag'
                            tooltip='Управление тегами'
                            text='Теги' />
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column>
                        <Text text='Имя' />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem
                        press='onPressListItem'
                        navigated='{= %{/detailID} === %{todo>ID} }'
                        highlight='{= %{/detailID} === %{todo>ID} ? "Information" : "None" }'
                        type='{= %{/detailID} === %{todo>ID} ? "Active" : "Navigation" }'>
                        <cells>
                            <ObjectIdentifier title='{todo>name}' />
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>
        </f:content>

    </f:DynamicPage>

</mvc:View>