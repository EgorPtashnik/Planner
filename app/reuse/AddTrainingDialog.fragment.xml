<core:FragmentDefinition
    xmlns='sap.m'
    xmlns:form='sap.ui.layout.form'
    xmlns:core='sap.ui.core'>

    <Dialog
        title='Записать Тренировку'>

        <content>
            <form:SimpleForm layout='ColumnLayout'>
                <Label text='Тип' />
                <RadioButtonGroup
                    columns='2'
                    selectedIndex='{state>/AddTrainingDialog/selectedType}'>
                    <RadioButton text='Одиночная' />
                    <RadioButton text='Групповая' />
                </RadioButtonGroup>
                
                <Label text='Дата' />
                <DatePicker dateValue='{state>/AddTrainingDialog/date}' />
            </form:SimpleForm>
        </content>

        <buttons>
            <Button
                press='onAddTraining'
                type='Emphasized'
                text='Записать'
                tooltip='Записать' />
            <Button
                press='onPressCloseDialog'
                text='Закрыть'
                tooltip='Закрыть' />
        </buttons>
    </Dialog>

</core:FragmentDefinition>