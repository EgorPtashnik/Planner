{
    "name": "PlanneR",
    "display": "standalone",
    "icons": [{
        "src": "icons/512.png",
        "type": "image/png",
        "sizes": "512x512"
    }],
    "start_url": "./",

    "_version": "1.38.0",
    "sap.app": {
        "id": "planner",
        "type": "application",
        "applicationVersion": {
            "version": "1.0.0"
        },
        "dataSources": {
            "commonService": {
                "uri": "/odata/v4/common/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            },
            "todoService": {
                "uri": "/odata/v4/todo/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            },
            "gymService": {
                "uri": "/odata/v4/gym/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            },
            "armaService": {
                "uri": "/odata/v4/arma/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            }
        }
    },
    "sap.ui5": {
        "resources": { "css": [ { "uri": "style.css" } ] },
        "config": { "fullWidth": true },
        "dependencies": {
            "minUI5Version": "1.98.0",
            "libs": {
                "sap.ui.core": {},
                "sap.m": {},
                "sap.f": {},
                "sap.uxap": {},
                "sap.ui.layout": {},
                "sap.ui.unified": {},
                "sap.fe.placeholder": { "lazy": false }
            }
        },
        "models": {
            "common": { "dataSource": "commonService", "type": "sap.ui.model.odata.v4.ODataModel" },
            "todo": { "dataSource": "todoService", "type": "sap.ui.model.odata.v4.ODataModel" },
            "gym": { "dataSource": "gymService", "type": "sap.ui.model.odata.v4.ODataModel" },
            "arma": { "dataSource": "armaService", "type": "sap.ui.model.odata.v4.ODataModel" }
        },
        "rootView": {
            "viewName": "planner.pages.app.App",
            "type": "XML",
            "async": true,
            "id": "app"
        },
        "routing": {
            "config": {
                "routerClass": "sap.f.routing.Router",
                "type": "View",
                "viewType": "XML",
                "path": "planner.pages",
                "controlId": "app",
                "transition": "slide",
                "async": "true"
            },
            "routes": [
                {
                    "pattern": "",
                    "name": "home",
                    "target": ["home"]
                },

                {
                    "pattern": "todo",
                    "name": "todoMaster",
                    "target": ["todoMaster"]
                },
                {
                    "pattern": "todo/{id}/:layout:",
                    "name": "todoDetail",
                    "target": ["todoMaster", "todoDetail"]
                },

                {
                    "pattern": "gym",
                    "name": "gym",
                    "target": ["gym"]
                },

                {
                    "pattern": "arma/sqf",
                    "name": "sqfMaster",
                    "target": ["sqfMaster"]
                },
                {
                    "pattern": "arma/sqf/{id}/:layout:",
                    "name": "sqfDetail",
                    "target": ["sqfMaster", "sqfDetail"]
                }
            ],
            "targets": {
                "home": {
                    "name": "home.Home",
                    "controlAggregation": "beginColumnPages",
                    "placeholder": {
                        "html": "sap/fe/placeholder/view/PlaceholderOVP.fragment.html",
                        "autoClose": true
                    }
                },

                "todoMaster": {
                    "name": "todo.master.TodoMaster",
                    "controlAggregation": "beginColumnPages",
                    "placeholder": {
                        "html": "sap/fe/placeholder/view/PlaceholderLR.fragment.html",
                        "autoClose": true
                    }
                },
                "todoDetail": {
                    "name": "todo.detail.TodoDetail",
                    "controlAggregation": "midColumnPages",
                    "placeholder": {
                        "html": "sap/fe/placeholder/view/PlaceholderOP.fragment.html",
                        "autoClose": true
                    }
                },

                "gym": {
                    "name": "gym.Gym",
                    "controlAggregation": "beginColumnPages",
                    "placeholder": {
                        "html": "sap/fe/placeholder/view/PlaceholderOP.fragment.html",
                        "autoClose": true
                    }
                },

                "sqfMaster": {
                    "name": "arma.sqf.master.SQFMaster",
                    "controlAggregation": "beginColumnPages",
                    "placeholder": {
                        "html": "sap/fe/placeholder/view/PlaceholderLR.fragment.html",
                        "autoClose": true
                    }
                },
                "sqfDetail": {
                    "name": "arma.sqf.detail.SQFDetail",
                    "controlAggregation": "midColumnPages",
                    "placeholder": {
                        "html": "sap/fe/placeholder/view/PlaceholderOP.fragment.html",
                        "autoClose": true
                    }
                }

            }
        }
    }
}