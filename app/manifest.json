{
    "_version": "1.38.0",
    "sap.app": {
        "id": "planner",
        "type": "application",
        "applicationVersion": {
            "version": "1.0.0"
        },
        "dataSources": {
            "commonService": {
                "uri": "/odata/v4/common/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            },
            "todo": {
                "uri": "/odata/v4/todo/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            }
        }
    },
    "sap.ui5": {
        "config": { "fullWidth": true },
        "dependencies": {
            "minUI5Version": "1.98.0",
            "libs": {
                "sap.ui.core": {},
                "sap.m": {},
                "sap.f": {},
                "sap.fe.placeholder": { "lazy": false }
            }
        },
        "models": {
            "common": { "dataSource": "commonService", "type": "sap.ui.model.odata.v4.ODataModel" },
            "todo": { "dataSource": "todo", "type": "sap.ui.model.odata.v4.ODataModel" }
        },
        "rootView": {
            "viewName": "planner.view.app.App",
            "type": "XML",
            "async": true,
            "id": "app"
        },
        "routing": {
            "config": {
                "routerClass": "sap.f.routing.Router",
                "type": "View",
                "viewType": "XML",
                "path": "planner.view",
                "controlId": "app",
                "transition": "slide",
                "async": "true"
            },
            "routes": [
                {
                    "pattern": "",
                    "name": "home",
                    "target": ["home"]
                },
                {
                    "pattern": "todo",
                    "name": "todoMaster",
                    "target": ["todoMaster"]
                },
                {
                    "pattern": "todo/{id}/:layout:",
                    "name": "todoDetail",
                    "target": ["todoMaster", "todoDetail"]
                },
                {
                    "pattern": "todo/{id}/{item}/:layout:",
                    "name": "todoDetailDetail",
                    "target": ["todoMaster", "todoDetail", "todoDetailDetail"]
                }
            ],
            "targets": {
                "home": {
                    "name": "home.Home",
                    "controlAggregation": "beginColumnPages",
                    "placeholder": {
                        "html": "sap/fe/placeholder/view/PlaceholderOP.fragment.html",
                        "autoClose": true
                    }
                },
                "todoMaster": {
                    "name": "todo.master.TodoMaster",
                    "controlAggregation": "beginColumnPages",
                    "placeholder": {
                        "html": "sap/fe/placeholder/view/PlaceholderLR.fragment.html",
                        "autoClose": true
                    }
                },
                "todoDetail": {
                    "name": "todo.detail.TodoDetail",
                    "controlAggregation": "midColumnPages",
                    "placeholder": {
                        "html": "sap/fe/placeholder/view/PlaceholderOP.fragment.html",
                        "autoClose": true
                    }
                },
                "todoDetailDetail": {
                    "name": "todo.detailDetail.TodoDetailDetail",
                    "controlAggregation": "endColumnPages",
                    "placeholder": {
                        "html": "sap/fe/placeholder/view/PlaceholderOP.fragment.html",
                        "autoClose": true
                    }
                }
            }
        }
    }
}