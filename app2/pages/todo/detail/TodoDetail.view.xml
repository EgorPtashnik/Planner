<mvc:View
    xmlns='sap.m'
    xmlns:uxap='sap.uxap'
    xmlns:core='sap.ui.core'
    xmlns:mvc='sap.ui.core.mvc'
    busyIndicatorDelay='0'
	controllerName='planner.pages.todo.detail.TodoDetail'>

    <uxap:ObjectPageLayout upperCaseAnchorBar='false'>

        <!-- ITEMS -->
        <uxap:sections>
            <uxap:ObjectPageSection showTitle='false'>
                <uxap:subSections>
                    <uxap:ObjectPageSubSection showTitle='false'>

                        <uxap:blocks>
                            <Table
                                id='idTodoItems'
                                showSeparators='Inner'
                                autoPopinMode='true'
                                hiddenInPopin='{= %{config>/showDetails}.toString() === "true" || %{config>/editMode} ? [] : ["Low","Medium"] }'
                                mode='{= %{config>/editMode} ? "Delete" : "None"}'
                                items='{
                                    path: "todo>items",
                                    parameters: {
                                        $$ownRequest: true,
                                        $count: true,
                                        $orderby: "createdAt desc"
                                    }
                                }'>

                                <headerToolbar>
                                    <OverflowToolbar>

                                        <OverflowToolbarButton
                                            press='onPressDeleteCompletedItems'
                                            type='Transparent'
                                            icon='sap-icon://eraser'
                                            text='Удалить Законченные'
                                            tooltip='Удалить Законченные'
                                            visible='{= !%{config>/editMode} }'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData group='1' />
                                            </layoutData>
                                        </OverflowToolbarButton>

                                        <OverflowToolbarButton
                                            press='onPressItemSort'
                                            type='Transparent'
                                            icon='sap-icon://sort'
                                            text='Сортировка'
                                            tooltip='Сортировка'>
                                            <layoutData>
                                                <OverflowToolbarLayoutData group='1' />
                                            </layoutData>
                                        </OverflowToolbarButton>
                                    </OverflowToolbar>
                                </headerToolbar>

                                <columns>
                                    <Column
                                        width='auto'
                                        autoPopinWidth='10'
                                        importance='High' >
                                        <Text text='Имя'/>
                                    </Column>

                                    <Column
                                        width='8rem'
                                        importance='Medium'
                                        popinDisplay='Inline'>
                                        <Text text='Приоритет' />
                                    </Column>

                                    <Column
                                        importance='Low'
                                        autoPopinWidth='999'
                                        popinDisplay='{= %{config>/editMode} ? "Block" : "WithoutHeader" }'>
                                        <Text text='Заметка' />
                                    </Column>

                                    <Column
                                        width='8rem'
                                        hAlign='Right'
                                        importance='High'
                                        visible='{= !%{config>/editMode} }'>
                                        <Text text='Выполнение' />
                                    </Column>
                                </columns>

                                <items>
                                    <ColumnListItem
                                        visible='{=
                                            %{config>/showCompletedItems} ||
                                            %{todo>status} === 0 || %{todo>status} === 1
                                        }'>
                                        <cells>
                                            <VBox>
                                                <!-- DISPLAY -->
                                                <ObjectIdentifier
                                                    title='{todo>name}'
                                                    visible='{= !%{config>/editMode} }'/>
                                                <!-- EDIT -->
                                                <Input
                                                    width='100%'
                                                    value='{todo>name}'
                                                    visible='{config>/editMode}' />
                                            </VBox>

                                            <VBox>
                                                <!-- DISPLAY -->
                                                <ObjectStatus
                                                    text='{ path: "todo>priority", formatter: ".Formatter.getPriorityText" }'
                                                    state='{ path: "todo>priority", formatter: ".Formatter.getPriorityState" }'
                                                    visible='{= !%{config>/editMode} }' />
                                                <!-- EDIT -->
                                                <Select
                                                    width='100%'
                                                    selectedKey='{todo>priority}'
                                                    visible='{config>/editMode}'
                                                    items='{path: "common>/PriorityCode", templateShareable: false}'>
                                                    <items>
                                                        <core:Item key='{common>code}' text='{common>name}' />
                                                    </items>
                                                </Select>
                                            </VBox>

                                            <VBox>
                                                <!-- DISPLAY -->
                                                <ExpandableText
                                                    maxCharacters='50'
                                                    emptyIndicatorMode='{= !!%{todo>info} ? "Off" : "On" }'
                                                    text='{todo>info}'
                                                    visible='{= !%{config>/editMode} }' />
                                                <!-- EDIT -->
                                                <TextArea
                                                    width='100%'
                                                    rows='1'
                                                    growing='true'  
                                                    value='{todo>info}'
                                                    visible='{config>/editMode}' />
                                            </VBox>

                                            <OverflowToolbar style='Clear'>
                                                <ToolbarSpacer />

                                                <Button
                                                    press='onPressChangeItemStatus($event, 1)'
                                                    type='Accept'
                                                    text='Начать'
                                                    tooltip='Начать'
                                                    visible='{= %{todo>status} === 0 &amp;&amp; !%{config>/editMode} }'>
                                                    <layoutData>
                                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                                    </layoutData>
                                                </Button>

                                                <Button
                                                    press='onPressChangeItemStatus($event, 2)'
                                                    type='Accept'
                                                    icon='sap-icon://accept'
                                                    tooltip='Завершить'
                                                    visible='{= %{todo>status} === 1 &amp;&amp; !%{config>/editMode} }'>
                                                    <layoutData>
                                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                                    </layoutData>
                                                </Button>

                                                <Button
                                                    press='onPressChangeItemStatus($event, 3)'
                                                    type='Reject'
                                                    icon='sap-icon://decline'
                                                    tooltip='Отменить'
                                                    visible='{= %{todo>status} === 1 &amp;&amp; !%{config>/editMode} }'>
                                                    <layoutData>
                                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                                    </layoutData>
                                                </Button>

                                                <ObjectStatus
                                                    inverted='true'
                                                    icon='{= %{todo>status} === 2 ? "sap-icon://accept" : "sap-icon://decline"}'
                                                    text='{path: "todo>status", formatter: ".Formatter.getProgressStatusText"}' 
                                                    state='{path: "todo>status", formatter: ".Formatter.getProgressStatusState"}'
                                                    visible='{= %{todo>status} &gt; 1 &amp;&amp; !%{config>/editMode} }'>
                                                    <layoutData>
                                                        <OverflowToolbarLayoutData priority='NeverOverflow' />
                                                    </layoutData>
                                                </ObjectStatus>
                                            </OverflowToolbar>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:blocks>

                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>

    </uxap:ObjectPageLayout>

</mvc:View>